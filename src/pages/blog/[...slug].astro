---
import BaseLayout from "@layouts/BaseLayout.astro";
import SchemaOrg from "@components/seo/SchemaOrg.astro";
import { getCollection, getEntry, render } from "astro:content";
import { getRelatedArticles, getAllCategories } from "@lib/content/posts";
import { formatDate } from "@lib/utils/dateFormat";
import { calculateReadingTime } from "@lib/utils/readingTime";
import { buildCanonical } from "@lib/seo/metadata";
import { extractHeadings } from "@lib/content/headings";
import TableOfContents from "@components/content/TableOfContents.astro";
import AuthorBox from "@components/content/AuthorBox.astro";
import SocialShare from "@components/content/SocialShare.astro";
import ArticleCard from "@components/content/ArticleCard.astro";
import References from "@components/content/References.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles
    .filter((a) => !a.data.draft)
    .map((article) => ({
      params: { slug: article.id },
      props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const relatedArticles = await getRelatedArticles(article, 3);
const author = await getEntry("authors", article.data.author);
const readingTime = article.data.readingTime || calculateReadingTime(article.body || article.data.description);
const articleUrl = buildCanonical("https://www.praveentechworld.com", `/blog/${article.id}`);
const headings = extractHeadings(article.body || "");

const breadcrumbItems = [
  { name: "Home", url: "https://www.praveentechworld.com/" },
  { name: "Blog", url: "https://www.praveentechworld.com/blog" },
  { name: article.data.seoTitle || article.data.title, url: articleUrl },
];

// Extract HowTo steps from headings containing "Step" or numbered steps
function extractHowToSteps(body, baseUrl) {
  const stepRegex = /^#{2,3}\s+(Step\s+\d+[:.]?\s*.+)$/gm;
  const steps = [];
  let match;
  while ((match = stepRegex.exec(body || "")) !== null) {
    const name = match[1].trim();
    const stepNum = name.match(/Step\s+(\d+)/i);
    const index = stepNum ? parseInt(stepNum[1]) : steps.length + 1;
    steps.push({ name, text: name, url: `${baseUrl}#step-${index}` });
  }
  return steps.length > 0 ? steps : null;
}

const howToSteps = extractHowToSteps(article.body, articleUrl);
const howToData = howToSteps ? {
  name: article.data.seoTitle || article.data.title,
  description: article.data.description || "",
  steps: howToSteps,
  image: article.data.coverImage,
} : null;
---

<BaseLayout
  seo={{
    title: article.data.seoTitle || article.data.title,
    description: article.data.seoDescription || article.data.description,
    canonical: article.data.canonical,
    ogImage: article.data.coverImage,
    ogType: "article",
  }}
>
  <!-- Reading progress bar -->
  <div id="reading-progress"></div>
  <SchemaOrg
    type="article"
    articleData={{
      title: article.data.title,
      description: article.data.description,
      url: articleUrl,
      publishDate: article.data.publishDate.toISOString(),
      updatedDate: article.data.updatedDate?.toISOString(),
      authorName: author?.data.name || "Praveen",
      image: article.data.coverImage,
      tags: article.data.tags,
    }}
  />
  <SchemaOrg
    type="breadcrumb"
    breadcrumbItems={breadcrumbItems}
  />
  {article.data.faq && article.data.faq.length > 0 && (
    <SchemaOrg type="faq" faqItems={article.data.faq} />
  )}
  {howToData && howToData.steps.length >= 2 && (
    <SchemaOrg type="howto" howToData={howToData} />
  )}
  <SchemaOrg
    type="speakable"
    articleData={{ title: article.data.seoTitle || article.data.title, url: articleUrl }}
    speakableItems={[
      { cssSelector: "h1" },
      { cssSelector: ".prose > h2:first-of-type + p" },
      { cssSelector: ".prose > h2:first-of-type" },
    ]}
  />

  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-10">
      <article>
        <nav class="mb-6 text-sm text-text-muted dark:text-text-dark-muted">
          <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
          <span class="mx-2">/</span>
          <a href="/blog" class="hover:text-brand-600 dark:hover:text-brand-400">Blog</a>
          <span class="mx-2">/</span>
          <a href={`/guides/${article.data.category}`} class="hover:text-brand-600 dark:hover:text-brand-400">{article.data.category.replace(/-/g, " ")}</a>
        </nav>

        <a
          href={`/guides/${article.data.category}`}
          class="mb-6 flex items-center gap-2 rounded-lg border border-brand-200 bg-brand-50 px-4 py-3 text-sm font-medium text-brand-700 transition-colors hover:bg-brand-100 dark:border-brand-800 dark:bg-brand-900/20 dark:text-brand-300 dark:hover:bg-brand-900/30"
        >
          <svg class="h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
          </svg>
          Part of our <strong>{article.data.category.replace(/-/g, " ")} guide series</strong>
          <svg class="ml-auto h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>

        <header class="mb-8">
          <p class="mb-3 text-xs font-medium uppercase tracking-wider text-brand-600 dark:text-brand-400">
            {article.data.category}
          </p>
          <h1 class="mb-4 text-3xl font-bold tracking-tight md:text-4xl">
            {article.data.seoTitle || article.data.title}
          </h1>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-text-muted dark:text-text-dark-muted">
            {author && (
              <a href={`/author/${article.data.author}`} class="hover:text-brand-600 dark:hover:text-brand-400">
                {author.data.name}
              </a>
            )}
            <span class="hidden sm:inline">&bull;</span>
            <time datetime={article.data.publishDate.toISOString()}>
              Published {formatDate(article.data.publishDate)}
            </time>
            {article.data.updatedDate && article.data.updatedDate.toISOString() !== article.data.publishDate.toISOString() && (
              <>
                <span class="hidden sm:inline">&bull;</span>
                <time datetime={article.data.updatedDate.toISOString()}>
                  Updated {formatDate(article.data.updatedDate)}
                </time>
              </>
            )}
            <span class="hidden sm:inline">&bull;</span>
            <span>{readingTime} min read</span>
          </div>
          <div class="mt-4">
            <SocialShare url={articleUrl} title={article.data.seoTitle || article.data.title} />
          </div>
          {article.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {article.data.tags.map((tag) => {
                const tagSlug = tag.toLowerCase().replace(/\s+/g, "-");
                return (
                  <a href={`/tag/${tagSlug}`} class="inline-flex items-center rounded-full bg-surface-alt px-3 py-1 text-xs font-medium text-text-muted transition-colors hover:bg-brand-100 hover:text-brand-600 dark:bg-surface-dark-alt dark:hover:bg-brand-900/30 dark:hover:text-brand-400">
                    #{tag}
                  </a>
                );
              })}
            </div>
          )}
        </header>

        {article.data.coverImage && (
          <figure class="mb-8 overflow-hidden rounded-xl">
            <img src={article.data.coverImage} alt={article.data.imageAlt || article.data.title} width="800" height="400" class="w-full" loading="lazy" />
            {article.data.imageCredit && (
              <figcaption class="mt-1 text-xs text-text-muted dark:text-text-dark-muted">
                {article.data.imageCredit}
              </figcaption>
            )}
          </figure>
        )}
        <div class="prose max-w-none dark:prose-invert">
          <Content />
        </div>

        {article.data.faq && article.data.faq.length > 0 && (
          <div class="mt-12 border-t border-border dark:border-border-dark pt-8">
            <h2 class="text-2xl font-bold text-text dark:text-text-dark mb-6">Frequently Asked Questions</h2>
            <div class="space-y-4">
              {article.data.faq.map((item) => (
                <details open class="group border border-border dark:border-border-dark rounded-xl bg-surface dark:bg-surface-dark-alt p-5 transition-colors duration-300">
                  <summary class="list-none flex items-center justify-between font-bold text-base text-text dark:text-text-dark cursor-pointer">
                    <span>{item.question}</span>
                    <span class="text-brand-600 dark:text-brand-400 group-open:rotate-180 transition-transform duration-200">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <div class="mt-3 pt-3 border-t border-border/50 dark:border-border-dark/50 text-text-muted dark:text-text-dark-muted text-sm leading-relaxed">
                    {item.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        )}

        {article.data.references && article.data.references.length > 0 && (
          <References references={article.data.references} />
        )}

        <div class="mt-10">
          <AuthorBox author={author} />
        </div>

        <div class="mt-8 rounded-lg border border-border bg-surface p-5 dark:border-border-dark dark:bg-surface-dark">
          <p class="text-sm text-text-muted dark:text-text-dark-muted">
            <strong class="text-text dark:text-text-dark">Explore more:</strong>{" "}
            Browse all{" "}
            <a href={`/guides/${article.data.category}`} class="font-medium text-brand-600 hover:underline dark:text-brand-400">
              {article.data.category.replace(/-/g, " ")} guides
            </a>
            {" "}or check related articles below.
          </p>
        </div>
      </article>

      <aside class="lg:block">
        <div class="sticky top-20 space-y-8">
          <TableOfContents headings={headings} />
          {relatedArticles.length > 0 && (
            <section>
              <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-text-muted dark:text-text-dark-muted">
                More in {article.data.category}
              </h3>
              <ul class="space-y-3">
                {relatedArticles.slice(0, 2).map((r) => (
                  <li>
                    <a
                      href={`/blog/${r.id}`}
                      class="group block text-sm leading-snug transition-colors hover:text-brand-600 dark:hover:text-brand-400"
                    >
                      <span class="line-clamp-2 group-hover:underline">
                        {r.data.seoTitle || r.data.title}
                      </span>
                      <span class="mt-0.5 block text-xs text-text-muted dark:text-text-dark-muted">
                        {r.data.publishDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
              <a
                href={`/guides/${article.data.category}`}
                class="mt-3 inline-block text-xs font-medium text-brand-600 hover:underline dark:text-brand-400"
              >
                View all &rarr;
              </a>
            </section>
          )}
        </div>
      </aside>
    </div>
  </div>

  <div class="border-t border-border dark:border-border-dark">
    <div class="mx-auto max-w-6xl px-4 py-12">
      {article.data.tags.length > 0 && (
        <section class="mb-8 rounded-xl border border-border bg-surface-alt p-6 dark:border-border-dark dark:bg-surface-dark-alt">
          <h2 class="mb-4 text-lg font-bold text-text dark:text-text-dark">Topics</h2>
          <div class="flex flex-wrap gap-2">
            {article.data.tags.map((tag) => {
              const tagSlug = tag.toLowerCase().replace(/\s+/g, "-");
              return (
                <a
                  href={`/tag/${tagSlug}`}
                  class="inline-flex items-center rounded-full bg-surface px-3 py-1 text-xs font-medium text-text-muted transition-colors hover:bg-brand-100 hover:text-brand-600 dark:bg-surface-dark dark:hover:bg-brand-900/30 dark:hover:text-brand-400"
                >
                  #{tag}
                </a>
              );
            })}
          </div>
        </section>
      )}

      {relatedArticles.length > 0 && (
        <section>
          <h2 class="mb-6 text-2xl font-bold">Related Articles</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {relatedArticles.map((related) => (
              <ArticleCard article={related} />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>

  <script>
    // Reading progress bar — cache docHeight to avoid forced reflow on scroll
    const progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      let docHeight = 0;
      function measureHeight() {
        docHeight = document.documentElement.scrollHeight - window.innerHeight;
      }
      function updateProgress() {
        const scrollTop = window.scrollY;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = Math.min(progress, 100) + '%';
      }
      measureHeight();
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', measureHeight, { passive: true });
    }
  </script>
</BaseLayout>
