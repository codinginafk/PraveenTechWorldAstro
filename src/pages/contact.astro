---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  seo={{
    title: "Contact",
    description: "Get in touch with PraveenTechWorld. Send us your questions, suggestions, or feedback.",
  }}
>
  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="mb-3 text-3xl font-bold">Contact</h1>
    <p class="mb-10 text-text-muted dark:text-text-dark-muted">
      Have a question, suggestion, or feedback? Send us a message.
    </p>
    <form
      class="space-y-6"
      action="https://formspree.io/f/YOUR_FORM_ID" <!-- REPLACE with your Formspree form ID before deploy -->
      method="POST"
    >
      <div>
        <label for="name" class="mb-1 block text-sm font-medium text-text dark:text-text-dark">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted focus:border-brand-600 focus:outline-none dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:placeholder:text-text-dark-muted"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="email" class="mb-1 block text-sm font-medium text-text dark:text-text-dark">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted focus:border-brand-600 focus:outline-none dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:placeholder:text-text-dark-muted"
          placeholder="your@email.com"
        />
      </div>
      <div>
        <label for="message" class="mb-1 block text-sm font-medium text-text dark:text-text-dark">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted focus:border-brand-600 focus:outline-none dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:placeholder:text-text-dark-muted"
          placeholder="Your message..."
        ></textarea>
      </div>
      <button
        type="submit"
        class="rounded-lg bg-brand-600 px-8 py-3 text-sm font-medium text-white transition-all hover:bg-brand-700"
      >
        Send Message
      </button>
    </form>
    <p class="mt-8 text-sm text-text-muted dark:text-text-dark-muted">
      You can also email us directly at{" "}
      <a href="mailto:hello@praveentechworld.com" class="text-brand-600 hover:underline dark:text-brand-400">
        hello@praveentechworld.com
      </a>.
    </p>
  </div>
</BaseLayout>
