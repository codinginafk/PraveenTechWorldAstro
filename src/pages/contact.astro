---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  seo={{
    title: "Contact Us — Get in Touch with PraveenTechWorld",
    description: "Have a question or suggestion? Get in touch with PraveenTechWorld. Send us your feedback or ask about our technology guides and tutorials.",
  }}
>
  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="mb-3 text-3xl font-bold">Contact</h1>
    <p class="mb-4 text-text-muted dark:text-text-dark-muted">
      Have a question, suggestion, or feedback? Send us a message.
    </p>
    <p class="mb-4 text-sm text-text-muted dark:text-text-dark-muted">
      Based in Dubai, United Arab Emirates. Whether you found a broken link,
      want to suggest a topic, or need help with a guide, I read every message.
      Expect a response within 1-2 business days. I especially welcome suggestions
      for new guide topics and bug reports about any instructions that no longer work.
    </p>
    <p class="mb-4 text-sm text-text-muted dark:text-text-dark-muted">
      Before reaching out, check if your question is already answered in our
      guides. I write detailed step-by-step tutorials for common problems. If
      you cannot find what you need, send me a message with as much detail as
      possible. Include error messages, your operating system, and what you
      have already tried. This helps me give you a useful answer faster.
    </p>
    <p class="mb-10 text-sm text-text-muted dark:text-text-dark-muted">
      I also welcome guest post ideas and collaboration requests. If you have
      expertise in AI, IT operations, security, or productivity, and want to
      share it with our readers, let me know. I review every suggestion and
      respond to everyone who takes the time to write.
    </p>
    <form
      class="space-y-6"
      action="https://formspree.io/f/xbdejjpr"
      method="POST"
      data-webmcp-tool="send_message"
      data-webmcp-description="Send a contact message to the site owner"
    >
      <div>
        <label for="name" class="mb-1 block text-sm font-medium text-text dark:text-text-dark">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted focus:border-brand-600 focus:outline-none dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:placeholder:text-text-dark-muted"
          placeholder="Your name"
        />
      </div>
      <div>
        <label for="email" class="mb-1 block text-sm font-medium text-text dark:text-text-dark">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted focus:border-brand-600 focus:outline-none dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:placeholder:text-text-dark-muted"
          placeholder="your@email.com"
        />
      </div>
      <div>
        <label for="message" class="mb-1 block text-sm font-medium text-text dark:text-text-dark">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full rounded-lg border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted focus:border-brand-600 focus:outline-none dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:placeholder:text-text-dark-muted"
          placeholder="Your message..."
        ></textarea>
      </div>
      <button
        type="submit"
        class="rounded-lg bg-brand-600 px-8 py-3 text-sm font-medium text-white transition-all hover:bg-brand-700"
      >
        Send Message
      </button>
    </form>
    <p class="mt-8 text-sm text-text-muted dark:text-text-dark-muted">
      You can also email us directly at{" "}
      <a href="mailto:hello@praveentechworld.com" class="text-brand-600 hover:underline dark:text-brand-400">
        hello@praveentechworld.com
      </a>.
    </p>
  </div>
</BaseLayout>
