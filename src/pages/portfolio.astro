---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  seo={{
    title: "Praveen Kumar Mishra — Digital Marketing, Graphic Design & IT Portfolio",
    description: "Graphic Designer & Digital Marketer with an IT backbone. End-to-end visual content creation, e-commerce brand building, video editing, and website design.",
  }}
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">

    <!-- Hero Section -->
    <section class="relative mb-20 overflow-hidden rounded-3xl border border-border bg-surface-alt/30 p-8 dark:border-border-dark dark:bg-surface-dark-alt/20 md:p-12">
      <!-- Glow decoration -->
      <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-500/10 blur-[100px] dark:bg-brand-400/15"></div>
      <div class="absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-accent-500/5 blur-[100px] dark:bg-accent-400/10"></div>

      <div class="relative z-10 flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-4 max-w-3xl">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-3.5 py-1 text-xs font-semibold tracking-wider text-brand-700 uppercase dark:bg-brand-900/40 dark:text-brand-300">
            Available for Opportunities
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight text-text dark:text-text-dark sm:text-5xl lg:text-6xl">
            Praveen Kumar Mishra
          </h1>
          <p class="text-lg font-medium text-brand-600 dark:text-brand-400">
            Graphic Designer & Digital Marketer <span class="mx-1 text-text-muted dark:text-text-dark-muted">|</span> IT Professional
          </p>
          <p class="text-base text-text-muted dark:text-text-dark-muted leading-relaxed">
            Creative-first designer with a strong IT engineering backbone. Over 4 years of hands-on experience managing the full digital presence, visual assets, and marketing campaigns for multi-site retail brands alongside personal digital creations.
          </p>
          <div class="flex flex-wrap gap-3 pt-2 text-xs">
            <span class="rounded-lg border border-border bg-surface px-3 py-1.5 dark:border-border-dark dark:bg-surface-dark">📍 Dubai, UAE</span>
            <span class="rounded-lg border border-border bg-surface px-3 py-1.5 dark:border-border-dark dark:bg-surface-dark">🇦🇪 Valid UAE Residence Visa</span>
            <span class="rounded-lg border border-border bg-surface px-3 py-1.5 dark:border-border-dark dark:bg-surface-dark">🚀 Immediate Availability</span>
          </div>
        </div>

        <div class="flex flex-col gap-3 shrink-0 w-full md:w-auto mt-6 md:mt-0">
          <a href="/Praveen_Graphic_Designer.pdf" download
            class="flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/20 active:scale-[0.98]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Download PDF Resume
          </a>
          <a href="https://www.linkedin.com/in/praveen-kumar-says/" target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 rounded-xl border border-border bg-surface px-5 py-3 text-sm font-semibold text-text transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:hover:border-brand-400 dark:hover:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Connect on LinkedIn
          </a>
          <a href="mailto:MishratWork@gmail.com"
            class="flex items-center justify-center gap-2 rounded-xl border border-border bg-surface px-5 py-3 text-sm font-semibold text-text transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:hover:border-brand-400 dark:hover:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            MishratWork@gmail.com
          </a>
        </div>
      </div>
    </section>

    <!-- Executive Highlights -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-6 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">⭐</span>
        Why I Bring a Unique Edge
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark hover:border-brand-200 dark:hover:border-brand-900/40 transition-all bg-surface/50 dark:bg-surface-dark/30">
          <div class="text-3xl mb-4">🎨</div>
          <h3 class="text-lg font-bold text-text dark:text-text-dark mb-2">Creative-First Design</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
            Specialized in translating marketing ideas into pixel-perfect assets: website banners, app notification graphics, logos, and printed brand identity.
          </p>
        </div>
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark hover:border-brand-200 dark:hover:border-brand-900/40 transition-all bg-surface/50 dark:bg-surface-dark/30">
          <div class="text-3xl mb-4">📈</div>
          <h3 class="text-lg font-bold text-text dark:text-text-dark mb-2">Direct Digital ROI</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
            Experienced running paid ads, content planning, and social campaigns for a 35+ store branch chain, driving active user engagement and traffic growth.
          </p>
        </div>
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark hover:border-brand-200 dark:hover:border-brand-900/40 transition-all bg-surface/50 dark:bg-surface-dark/30">
          <div class="text-3xl mb-4">💻</div>
          <h3 class="text-lg font-bold text-text dark:text-text-dark mb-2">Strong IT Backbone</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
            B.Tech in Computer Science allows me to design with technical precision, understanding code limits, layouts, page speed, and deployment stacks.
          </p>
        </div>
      </div>
    </section>

    <!-- Skills & Tools Grid -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">🛠️</span>
        Skills & Tools Inventory
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- Design -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface-alt/10 dark:bg-surface-dark-alt/5">
          <h3 class="text-lg font-bold text-brand-600 dark:text-brand-400 mb-4 flex items-center gap-2">
            <span>🎨</span> Graphic Design
          </h3>
          <ul class="space-y-2.5">
            {[
              "Adobe Photoshop",
              "Adobe Express",
              "Adobe Lightroom",
              "Canva",
              "Brand Identity Design",
              "Social Media Creatives",
              "Banner & Ad Design",
              "App Assets & UI Graphics"
            ].map(skill => (
              <li class="flex items-center gap-2 text-sm text-text-muted dark:text-text-dark-muted">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>

        <!-- Video & Marketing -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface-alt/10 dark:bg-surface-dark-alt/5">
          <h3 class="text-lg font-bold text-brand-600 dark:text-brand-400 mb-4 flex items-center gap-2">
            <span>📹</span> Video & Marketing
          </h3>
          <ul class="space-y-2.5">
            {[
              "Adobe Premiere Pro",
              "DaVinci Resolve",
              "CapCut & Filmora",
              "Social Media Strategy",
              "Instagram & FB Campaigns",
              "E-commerce Marketing",
              "Content Planning",
              "Push Notification Design"
            ].map(skill => (
              <li class="flex items-center gap-2 text-sm text-text-muted dark:text-text-dark-muted">
                <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>

        <!-- IT & Web Edge -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface-alt/10 dark:bg-surface-dark-alt/5">
          <h3 class="text-lg font-bold text-brand-600 dark:text-brand-400 mb-4 flex items-center gap-2">
            <span>💻</span> IT & Web Edge
          </h3>
          <ul class="space-y-2.5">
            {[
              "Website Design & Deploy",
              "HTML / CSS / JS Basics",
              "Windows Server & AD",
              "Microsoft 365 Admin",
              "Network Admin (LAN/WAN)",
              "POS/PMS Systems",
              "SQL & Database Basics",
              "CMS & E-commerce Platforms"
            ].map(skill => (
              <li class="flex items-center gap-2 text-sm text-text-muted dark:text-text-dark-muted">
                <span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Project Showcase -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">💼</span>
        Live Projects & Case Studies
      </h2>

      <div class="space-y-12">
        <!-- NatureNest Gifts -->
        <div class="grid gap-8 md:grid-cols-12 items-center rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30">
          <div class="md:col-span-5 bg-gradient-to-br from-indigo-950 via-brand-950 to-purple-950 rounded-xl aspect-[4/3] p-6 flex flex-col justify-between border border-brand-500/20 relative overflow-hidden">
            <!-- Glow background -->
            <div class="absolute -bottom-12 -right-12 h-36 w-36 rounded-full bg-purple-500/30 blur-2xl"></div>
            <!-- Minimal SVG Graphic Representation -->
            <div class="flex items-center justify-between z-10">
              <span class="text-sm font-bold tracking-widest text-brand-300">NATURENEST GIFTS</span>
              <span class="text-xs border border-brand-400/30 px-2 py-0.5 rounded-full bg-brand-900/60 text-brand-200">E-Commerce Brand</span>
            </div>
            <div class="py-4 z-10 flex flex-col gap-1 items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="url(#candle-grad)" stroke-width="2" stroke-linecap="round" class="animate-bounce" viewBox="0 0 24 24">
                <defs>
                  <linearGradient id="candle-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#c084fc"/>
                    <stop offset="100%" stop-color="#4f46e5"/>
                  </linearGradient>
                </defs>
                <path d="M12 2c-.6 1.4-1 2.5-1 3.5 0 1.1.9 2 2 2s2-.9 2-2c0-1-.4-2.1-1-3.5z"/>
                <path d="M7 10h10v11H7z"/>
                <path d="M9 13h6"/>
                <path d="M9 17h6"/>
              </svg>
              <span class="text-xs text-text-dark-muted mt-2">Premium Wax & Candle Designs</span>
            </div>
            <div class="flex justify-between items-end z-10">
              <span class="text-2xl font-bold text-white">NatureNestGifts</span>
              <span class="text-xs text-brand-400">Launch 2026</span>
            </div>
          </div>
          <div class="md:col-span-7 space-y-4">
            <span class="text-xs font-semibold text-brand-600 dark:text-brand-400 uppercase tracking-wider">Digital Brand Creation (Personal Venture)</span>
            <h3 class="text-2xl font-bold text-text dark:text-text-dark">NatureNestGifts.vercel.app</h3>
            <p class="text-text-muted dark:text-text-dark-muted leading-relaxed">
              Designed, built, and launched a premium handcrafted wax & candle e-commerce platform from scratch. Took charge of end-to-end digital content production, graphic identity, UI website design, product mockups, and strategic social marketing execution.
            </p>
            <div class="flex flex-wrap gap-2 text-xs font-medium">
              <span class="rounded bg-brand-50 px-2 py-1 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">Brand Identity</span>
              <span class="rounded bg-brand-50 px-2 py-1 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">E-Commerce Web Design</span>
              <span class="rounded bg-brand-50 px-2 py-1 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">Wax Mockups</span>
            </div>
            <div class="pt-2">
              <a href="https://NatureNestGifts.vercel.app" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300">
                Launch Live Site
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Danish Saloon -->
        <div class="grid gap-8 md:grid-cols-12 items-center rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30">
          <div class="md:col-span-5 bg-gradient-to-br from-slate-900 via-emerald-950 to-teal-950 rounded-xl aspect-[4/3] p-6 flex flex-col justify-between border border-emerald-500/20 relative overflow-hidden">
            <!-- Glow background -->
            <div class="absolute -bottom-12 -right-12 h-36 w-36 rounded-full bg-emerald-500/20 blur-2xl"></div>
            <!-- Minimal SVG Graphic Representation -->
            <div class="flex items-center justify-between z-10">
              <span class="text-sm font-bold tracking-widest text-emerald-300">KOPILA SALON</span>
              <span class="text-xs border border-emerald-400/30 px-2 py-0.5 rounded-full bg-emerald-900/60 text-emerald-200">Client Web & Marketing</span>
            </div>
            <div class="py-4 z-10 flex flex-col gap-1 items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="url(#barber-grad)" stroke-width="2" stroke-linecap="round" class="animate-[spin_8s_linear_infinite]" viewBox="0 0 24 24">
                <defs>
                  <linearGradient id="barber-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#34d399"/>
                    <stop offset="100%" stop-color="#059669"/>
                  </linearGradient>
                </defs>
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 2v20"/>
                <path d="M17 17A7 7 0 1 0 7 7"/>
              </svg>
              <span class="text-xs text-text-dark-muted mt-2">Dubai Grooming Brand Concept</span>
            </div>
            <div class="flex justify-between items-end z-10">
              <span class="text-2xl font-bold text-white">Danish Saloon</span>
              <span class="text-xs text-emerald-400">Launch May 2026</span>
            </div>
          </div>
          <div class="md:col-span-7 space-y-4">
            <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400 uppercase tracking-wider">Web Design & Marketing Lead</span>
            <h3 class="text-2xl font-bold text-text dark:text-text-dark">danishsaloon.vercel.app</h3>
            <p class="text-text-muted dark:text-text-dark-muted leading-relaxed">
              Designed and developed a cohesive visual presentation and complete client site for a mens grooming brand in Dubai (Kopila Gents Salon). Handled UI structures, content planning, and logo Kit, building a unified layout across mobile and desktop.
            </p>
            <div class="flex flex-wrap gap-2 text-xs font-medium">
              <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">UI / UX Layout</span>
              <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">Local SEO</span>
              <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">Logo Design</span>
            </div>
            <div class="pt-2">
              <a href="https://danishsaloon.vercel.app/" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300">
                Launch Live Site
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Al Adil Trading -->
        <div class="grid gap-8 md:grid-cols-12 items-center rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30">
          <div class="md:col-span-5 bg-gradient-to-br from-orange-950 via-red-950 to-amber-950 rounded-xl aspect-[4/3] p-6 flex flex-col justify-between border border-amber-500/20 relative overflow-hidden">
            <!-- Glow background -->
            <div class="absolute -bottom-12 -right-12 h-36 w-36 rounded-full bg-amber-500/20 blur-2xl"></div>
            <!-- Minimal SVG Graphic Representation -->
            <div class="flex items-center justify-between z-10">
              <span class="text-sm font-bold tracking-widest text-amber-300">AL ADIL E-COMMERCE</span>
              <span class="text-xs border border-amber-400/30 px-2 py-0.5 rounded-full bg-amber-900/60 text-emerald-200">2.5 Years Admin</span>
            </div>
            <div class="py-4 z-10 flex flex-col gap-1 items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="url(#adil-grad)" stroke-width="2" stroke-linecap="round" class="animate-swing-bag" viewBox="0 0 24 24">
                <defs>
                  <linearGradient id="adil-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#fb923c"/>
                    <stop offset="100%" stop-color="#ea580c"/>
                  </linearGradient>
                </defs>
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                <line x1="3" x2="21" y1="6" y2="6"/>
                <path d="M16 10a4 4 0 0 1-8 0"/>
              </svg>
              <span class="text-xs text-text-dark-muted mt-2">Server Admin, Security & Updates</span>
            </div>
            <div class="flex justify-between items-end z-10">
              <span class="text-2xl font-bold text-white">Al Adil Group</span>
              <span class="text-xs text-orange-400">Scale & Security</span>
            </div>
          </div>
          <div class="md:col-span-7 space-y-4">
            <span class="text-xs font-semibold text-orange-600 dark:text-orange-400 uppercase tracking-wider">E-Commerce Technical & Operations Lead</span>
            <h3 class="text-2xl font-bold text-text dark:text-text-dark">adilstore.com & bh.adilstore.com</h3>
            <p class="text-text-muted dark:text-text-dark-muted leading-relaxed">
              Ran and managed the high-traffic e-commerce operations for one of the UAE's largest retail chains for 2.5 years. Led the platforms' hosting configurations, scaled server capacity to handle massive user/traffic spikes, protected websites from active cyber attacks, and updated structures to preserve search visibility through continuous Google Core updates. Reported and fixed application and shopping checkout bugs.
            </p>
            <div class="flex flex-wrap gap-2 text-xs font-medium">
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Cybersecurity Protection</span>
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Server Hosting & Scaling</span>
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Bug Fixing</span>
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Google Core Updates</span>
            </div>
            <div class="flex gap-4 pt-2">
              <a href="https://adilstore.com" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-brand-300">
                adilstore.com
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
              <a href="https://bh.adilstore.com" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-brand-300">
                bh.adilstore.com
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Masala King -->
        <div class="grid gap-8 md:grid-cols-12 items-center rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30">
          <div class="md:col-span-5 bg-gradient-to-br from-red-950 via-rose-950 to-orange-950 rounded-xl aspect-[4/3] p-6 flex flex-col justify-between border border-rose-500/20 relative overflow-hidden">
