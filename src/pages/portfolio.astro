---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  seo={{
    title: "Praveen Kumar Mishra — Digital Marketing, AI Content & E-Commerce Portfolio",
    description: "Digital Marketing Executive & AI Content Creator with an IT engineering backbone. Specialist in Google & Meta Ads, SEO/SEM, GA4, e-commerce operations, video editing, and technical web infrastructure.",
  }}
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">

    <!-- Hero Section -->
    <section class="relative mb-20 overflow-hidden rounded-3xl border border-border bg-surface-alt/30 p-8 dark:border-border-dark dark:bg-surface-dark-alt/20 md:p-12">
      <!-- Ambient Glows -->
      <div class="absolute -right-24 -top-24 h-80 w-80 rounded-full bg-brand-500/10 blur-[100px] dark:bg-brand-400/15"></div>
      <div class="absolute -bottom-24 -left-24 h-80 w-80 rounded-full bg-accent-500/5 blur-[100px] dark:bg-accent-400/10"></div>

      <div class="relative z-10 flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
        <div class="space-y-4 max-w-3xl">
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-3.5 py-1 text-xs font-semibold tracking-wider text-brand-700 uppercase dark:bg-brand-900/40 dark:text-brand-300">
              Immediate Joiner
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3.5 py-1 text-xs font-semibold tracking-wider text-emerald-700 uppercase dark:bg-emerald-900/40 dark:text-emerald-300">
              Valid UAE Residence Visa
            </span>
          </div>
          <h1 class="text-4xl font-extrabold tracking-tight text-text dark:text-text-dark sm:text-5xl lg:text-6xl">
            Praveen Kumar Mishra
          </h1>
          <p class="text-xl font-bold text-brand-600 dark:text-brand-400">
            Digital Marketing Executive <span class="mx-1 text-text-muted dark:text-text-dark-muted">|</span> AI Content Creator <span class="mx-1 text-text-muted dark:text-text-dark-muted">|</span> SEO, Paid Ads & E-Commerce
          </p>
          <p class="text-base text-text-muted dark:text-text-dark-muted leading-relaxed">
            Full-funnel digital marketer with hands-on experience running paid performance campaigns (Google & Meta Ads), advanced SEO/SEM strategies, and AI-driven content engines. Managed end-to-end e-commerce platforms and multi-channel marketplace operations (Noon, Carrefour, ElGrocer, InstaShop) alongside creative post-production across Premiere Pro, CapCut, Photoshop, and Canva.
          </p>
          <div class="flex flex-wrap gap-2.5 pt-2 text-xs font-medium">
            <span class="rounded-lg border border-border bg-surface px-3 py-1.5 dark:border-border-dark dark:bg-surface-dark">📍 Dubai, UAE (Open to Ajman)</span>
            <span class="rounded-lg border border-border bg-surface px-3 py-1.5 dark:border-border-dark dark:bg-surface-dark">✉️ MishratWork@gmail.com</span>
            <span class="rounded-lg border border-border bg-surface px-3 py-1.5 dark:border-border-dark dark:bg-surface-dark">🌐 praveentechworld.com</span>
          </div>
        </div>

        <div class="flex flex-col gap-3 shrink-0 w-full md:w-auto mt-6 md:mt-0">
          <a href="https://www.linkedin.com/in/praveen-kumar-says/" target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-5 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/20 active:scale-[0.98]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn Profile
          </a>
          <a href="mailto:MishratWork@gmail.com"
            class="flex items-center justify-center gap-2 rounded-xl border border-border bg-surface px-5 py-3 text-sm font-semibold text-text transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:text-text-dark dark:hover:border-brand-400 dark:hover:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Send Email
          </a>
        </div>
      </div>
    </section>

    <!-- Why I'm The Fit (Core Strengths) -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-6 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">⚡</span>
        Why I Bring a Unique Edge
      </h2>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark hover:border-brand-200 dark:hover:border-brand-900/40 transition-all bg-surface/50 dark:bg-surface-dark/30">
          <div class="text-3xl mb-4">🎯</div>
          <h3 class="text-lg font-bold text-text dark:text-text-dark mb-2">Full-Funnel Campaign Execution</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
            Run the complete digital marketing lifecycle: Google & Meta paid ads, SEO/SEM strategies, email marketing, analytics tracking, and Power BI performance reporting.
          </p>
        </div>
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark hover:border-brand-200 dark:hover:border-brand-900/40 transition-all bg-surface/50 dark:bg-surface-dark/30">
          <div class="text-3xl mb-4">🛒</div>
          <h3 class="text-lg font-bold text-text dark:text-text-dark mb-2">Proven E-Commerce & Marketplaces</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
            Hands-on management of live e-commerce stores (adilstore.com, bh.adilstore.com) plus multi-channel sync across Noon, Carrefour, ElGrocer, and InstaShop.
          </p>
        </div>
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark hover:border-brand-200 dark:hover:border-brand-900/40 transition-all bg-surface/50 dark:bg-surface-dark/30">
          <div class="text-3xl mb-4">🤖</div>
          <h3 class="text-lg font-bold text-text dark:text-text-dark mb-2">AI Content & Technical Depth</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
            CS Engineering background combined with AI content creation (ChatGPT, Gemini, Midjourney) and post-production (Premiere Pro, CapCut, Photoshop, Canva).
          </p>
        </div>
      </div>
    </section>

    <!-- Core Competencies Grid -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">🛠️</span>
        Core Competencies & Tool Inventory
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- Paid Ads & Analytics -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface-alt/10 dark:bg-surface-dark-alt/5">
          <h3 class="text-lg font-bold text-brand-600 dark:text-brand-400 mb-4 flex items-center gap-2">
            <span>📊</span> Paid Ads & Analytics
          </h3>
          <ul class="space-y-2.5">
            {[
              "Google Ads & Meta Ads Campaigns",
              "SEO / SEM Strategy & Execution",
              "Google Analytics 4 & Search Console",
              "Bing Webmaster Tools & AI Search",
              "Power BI Sales Dashboards",
              "ROAS & Performance Reporting",
              "Competitor & Market Analysis"
            ].map(skill => (
              <li class="flex items-center gap-2 text-sm text-text-muted dark:text-text-dark-muted">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>

        <!-- Creative & AI Video -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface-alt/10 dark:bg-surface-dark-alt/5">
          <h3 class="text-lg font-bold text-brand-600 dark:text-brand-400 mb-4 flex items-center gap-2">
            <span>🎬</span> Creative & AI Production
          </h3>
          <ul class="space-y-2.5">
            {[
              "Canva, Adobe Photoshop & Illustrator",
              "Video Editing (Premiere Pro, CapCut)",
              "AI Content Generation (ChatGPT, Gemini)",
              "Midjourney & Local FLUX Image Prompts",
              "Social Media Content Scheduling",
              "Email Marketing Campaigns",
              "Graphic Banners & Ad Creatives"
            ].map(skill => (
              <li class="flex items-center gap-2 text-sm text-text-muted dark:text-text-dark-muted">
                <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>

        <!-- E-Commerce & Technical Infrastructure -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface-alt/10 dark:bg-surface-dark-alt/5">
          <h3 class="text-lg font-bold text-brand-600 dark:text-brand-400 mb-4 flex items-center gap-2">
            <span>⚙️</span> E-Commerce & Web Ops
          </h3>
          <ul class="space-y-2.5">
            {[
              "Shopify, Magento & Custom Builds",
              "Marketplace Operations (Noon, Carrefour)",
              "ElGrocer & InstaShop Catalog Sync",
              "Website Hosting, DNS & SSL Setup",
              "Security Incident & Outage Response",
              "Vendor & Developer AMC Coordination",
              "Digital Asset Management"
            ].map(skill => (
              <li class="flex items-center gap-2 text-sm text-text-muted dark:text-text-dark-muted">
                <span class="h-1.5 w-1.5 rounded-full bg-indigo-500"></span>
                {skill}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Execution & Impact Pillars (Focusing on Work Done, Not Company Names) -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-4 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">💼</span>
        Key Digital Execution & Project Impact
      </h2>
      <p class="text-sm text-text-muted dark:text-text-dark-muted mb-10">
        A breakdown of the core digital marketing, e-commerce, and technical operations executed across live retail networks and independent digital projects:
      </p>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- Pillar 1: Paid Ads & Performance Marketing -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30 flex flex-col justify-between">
          <div class="space-y-3">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-brand-600 dark:text-brand-400">Pillar 01</span>
            <h3 class="text-xl font-bold text-text dark:text-text-dark">Paid Campaign Management & Growth</h3>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
              Planned, executed, and monitored Google Ads and Meta Ads campaigns for major retail e-commerce channels. Managed campaign budgets, audience targeting, and A/B ad creative testing to maximize brand awareness, traffic acquisition, and online sales conversions.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded bg-brand-50 px-2 py-1 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">Google Ads</span>
            <span class="rounded bg-brand-50 px-2 py-1 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">Meta Ads</span>
            <span class="rounded bg-brand-50 px-2 py-1 text-brand-700 dark:bg-brand-900/30 dark:text-brand-400">ROAS Tracking</span>
          </div>
        </div>

        <!-- Pillar 2: End-to-End E-Commerce & Marketplace Sync -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30 flex flex-col justify-between">
          <div class="space-y-3">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-amber-600 dark:text-amber-400">Pillar 02</span>
            <h3 class="text-xl font-bold text-text dark:text-text-dark">E-Commerce & Marketplace Management</h3>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
              Managed complete product listings, catalog updates, pricing rules, and promo banners across live e-commerce websites (adilstore.com & bh.adilstore.com). Synchronized product catalogs and promotional campaigns across regional marketplaces including Noon, Carrefour, ElGrocer, and InstaShop.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded bg-amber-50 px-2 py-1 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">Magento & Shopify</span>
            <span class="rounded bg-amber-50 px-2 py-1 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">Noon / Carrefour</span>
            <span class="rounded bg-amber-50 px-2 py-1 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">Catalog Operations</span>
          </div>
        </div>

        <!-- Pillar 3: AI Search Optimization & Content Engine -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30 flex flex-col justify-between">
          <div class="space-y-3">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">Pillar 03</span>
            <h3 class="text-xl font-bold text-text dark:text-text-dark">AI Content Creation & SEO/SEM</h3>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
              Developed search-engine-optimized and AI-search-friendly content strategies. Configured Google Search Console, Google Analytics 4, and Bing Webmaster Tools to track impressions, keyword gaps, and crawl statistics. Leveraged ChatGPT, Gemini, and Midjourney to accelerate content output while keeping high editorial quality.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">GA4 & GSC</span>
            <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">AI Search (GEO)</span>
            <span class="rounded bg-emerald-50 px-2 py-1 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">LLM Content Prompts</span>
          </div>
        </div>

        <!-- Pillar 4: Social Media, Email & Creative Media -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30 flex flex-col justify-between">
          <div class="space-y-3">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-purple-600 dark:text-purple-400">Pillar 04</span>
            <h3 class="text-xl font-bold text-text dark:text-text-dark">Creative Content & Social Media Scheduling</h3>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
              Designed graphic assets, video reels, and promotional banners using Canva, Photoshop, CapCut, and Premiere Pro. Planned and scheduled social media content calendars and designed engaging email marketing templates supporting customer retention.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded bg-purple-50 px-2 py-1 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400">Premiere Pro & CapCut</span>
            <span class="rounded bg-purple-50 px-2 py-1 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400">Photoshop & Canva</span>
            <span class="rounded bg-purple-50 px-2 py-1 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400">Email Marketing</span>
          </div>
        </div>

        <!-- Pillar 5: Website Maintenance & Power BI Reporting -->
        <div class="rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30 md:col-span-2 flex flex-col justify-between">
          <div class="space-y-3">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-indigo-600 dark:text-indigo-400">Pillar 05</span>
            <h3 class="text-xl font-bold text-text dark:text-text-dark">Technical Operations, Host Management & Analytics Reporting</h3>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">
              Managed DNS records, SSL certificates, server hosting, and CMS updates across multiple sites. Handled incident response during live site outages and security breaches. Built custom Power BI reporting dashboards to translate sales numbers and marketing campaign data into clear executive reports.
            </p>
          </div>
          <div class="mt-6 flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded bg-indigo-50 px-2 py-1 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400">Power BI Dashboards</span>
            <span class="rounded bg-indigo-50 px-2 py-1 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400">DNS & SSL Security</span>
            <span class="rounded bg-indigo-50 px-2 py-1 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400">Incident Management</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Live Digital Project Showcase -->
    <section class="mb-20">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-8 flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-100 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400 text-base">🖥️</span>
        Live Digital Platforms & Web Projects
      </h2>

      <div class="space-y-12">
        <!-- E-Commerce Live Projects (adilstore & bh.adilstore) -->
        <div class="grid gap-8 md:grid-cols-12 items-center rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30">
          <div class="md:col-span-5 bg-gradient-to-br from-orange-950 via-red-950 to-amber-950 rounded-xl aspect-[4/3] p-6 flex flex-col justify-between border border-amber-500/20 relative overflow-hidden">
            <div class="absolute -bottom-12 -right-12 h-36 w-36 rounded-full bg-amber-500/20 blur-2xl"></div>
            <div class="flex items-center justify-between z-10">
              <span class="text-sm font-bold tracking-widest text-amber-300">LIVE RETAIL E-COMMERCE</span>
              <span class="text-xs border border-amber-400/30 px-2 py-0.5 rounded-full bg-amber-900/60 text-emerald-200">End-to-End Managed</span>
            </div>
            <div class="py-4 z-10 flex flex-col gap-1 items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" stroke="url(#adil-grad)" stroke-width="2" stroke-linecap="round" class="animate-swing-bag" viewBox="0 0 24 24">
                <defs>
                  <linearGradient id="adil-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#fb923c"/>
                    <stop offset="100%" stop-color="#ea580c"/>
                  </linearGradient>
                </defs>
                <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                <line x1="3" x2="21" y1="6" y2="6"/>
                <path d="M16 10a4 4 0 0 1-8 0"/>
              </svg>
              <span class="text-xs text-text-dark-muted mt-2">Retail E-Commerce Infrastructure</span>
            </div>
            <div class="flex justify-between items-end z-10">
              <span class="text-2xl font-bold text-white">Live E-Com Platforms</span>
              <span class="text-xs text-orange-400">Magento & Marketplaces</span>
            </div>
          </div>
          <div class="md:col-span-7 space-y-4">
            <span class="text-xs font-semibold text-orange-600 dark:text-orange-400 uppercase tracking-wider">E-Commerce & Digital Marketing Operations</span>
            <h3 class="text-2xl font-bold text-text dark:text-text-dark">adilstore.com & bh.adilstore.com</h3>
            <p class="text-text-muted dark:text-text-dark-muted leading-relaxed">
              Managed end-to-end e-commerce operations, paid Google & Meta ad campaigns, catalog structures, and marketplace channels across 35+ retail branches. Handled server scaling, security protections, SSL/DNS setup, and checkout flow bug fixes.
            </p>
            <div class="flex flex-wrap gap-2 text-xs font-medium">
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Paid Ad Campaigns</span>
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Marketplace Catalog Sync</span>
              <span class="rounded bg-orange-50 px-2 py-1 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">Power BI Sales Dashboards</span>
            </div>
            <div class="flex gap-4 pt-2">
              <a href="https://adilstore.com" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-brand-300">
                adilstore.com
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
              <a href="https://bh.adilstore.com" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-semibold text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-brand-300">
                bh.adilstore.com
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" x2="17" y1="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- NatureNest Gifts (Personal E-Commerce Venture) -->
        <div class="grid gap-8 md:grid-cols-12 items-center rounded-2xl border border-border p-6 dark:border-border-dark bg-surface/50 dark:bg-surface-dark/30">
          <div class="md:col-span-5 bg-gradient-to-br from-indigo-950 via-brand-950 to-purple-950 rounded-xl aspect-[4/3] p-6 flex flex-col justify-between border border-brand-500/20 relative overflow-hidden">
            <div class="absolute -bottom-12 -right-12 h-36 w-36 rounded-full bg-purple-500/30 blur-2xl"></div>
