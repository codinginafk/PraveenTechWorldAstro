---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLatestArticles, getFeaturedArticles } from "@lib/content/posts";
import { getCollection } from "astro:content";
import ArticleCard from "@components/content/ArticleCard.astro";

const latestArticles = await getLatestArticles(6);
const featuredArticles = await getFeaturedArticles();
const categories = await getCollection("categories");

const topFeatured = featuredArticles[0] || latestArticles[0];
const otherFeatured = featuredArticles.slice(1, 3);
const remainingArticles = latestArticles.filter(art => art.id !== topFeatured?.id);
---

<BaseLayout
  seo={{
    title: "DeepSeek Automation & AI Scripts for IT Ops",
    description:
      "DeepSeek-powered automation scripts, data pipelines, and IT tools from an IT Ops Lead. Honest battle logs of AI experiments including what broke and how.",
  }}
>
  <!-- Minimal Modern Hero -->
  <section class="mx-auto max-w-4xl px-6 pt-16 pb-12 text-center">
    <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl mb-6">
      DeepSeek Automation <span class="bg-gradient-to-r from-brand-600 to-brand-400 dark:from-brand-500 dark:to-brand-300 bg-clip-text text-transparent">&amp; AI Scripts</span>
    </h1>
    <p class="text-lg text-text-muted dark:text-text-dark-muted max-w-2xl mx-auto leading-relaxed">
      Automation scripts, data pipelines, and IT tools. Documenting exactly what works, what breaks, and how to build in public with AI.
    </p>
  </section>

  <!-- Bento Grid Showcase (Content First) -->
  <section class="mx-auto max-w-6xl px-6 mb-16">
    <div class="grid gap-6 md:grid-cols-3">
      
      <!-- Card 1: Top Featured Article (Span 2) -->
      {topFeatured && (
        <div class="group md:col-span-2 relative overflow-hidden rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-6 md:p-8 flex flex-col justify-between min-h-[360px] transition-all duration-300 hover:shadow-xl hover:border-brand-600 dark:hover:border-brand-400">
          <div>
            <span class="inline-block px-3 py-1 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-brand-200/50 dark:border-brand-800/40">
              {topFeatured.data.category || "Feature"}
            </span>
            <a href={`/blog/${topFeatured.id}`} class="block group">
              <h3 class="text-2xl md:text-3xl font-extrabold tracking-tight text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-3">
                {topFeatured.data.title}
              </h3>
            </a>
            <p class="text-sm text-text-muted dark:text-text-dark-muted mb-6 leading-relaxed max-w-xl">
              {topFeatured.data.description}
            </p>
          </div>
          
          {topFeatured.data.coverImage ? (
            <div class="aspect-video w-full rounded-2xl overflow-hidden border border-border dark:border-border-dark/50">
              <img 
                src={topFeatured.data.coverImage} 
                alt={topFeatured.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="eager"
              />
            </div>
          ) : (
            <div class="aspect-video w-full rounded-2xl bg-gradient-to-br from-brand-600/15 via-brand-500/5 to-transparent border border-border dark:border-border-dark/50 flex items-center justify-center font-mono text-sm text-brand-600 dark:text-brand-400">
              [ {topFeatured.id}.py ]
            </div>
          )}
        </div>
      )}

      <!-- Card 2: Interactive Choose Goal List -->
      <div class="rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-6 md:p-8 flex flex-col justify-between min-h-[360px] transition-all duration-300 hover:shadow-xl">
        <div>
          <h3 class="text-xl font-bold tracking-tight text-text dark:text-text-dark mb-4">Choose Your Goal</h3>
          <nav class="flex flex-col gap-2">
            <a href="/guides/ai-workflows" class="group flex items-center justify-between p-3 rounded-xl border border-border/50 hover:border-brand-600 dark:border-border-dark/50 dark:hover:border-brand-400 transition-all">
              <span class="text-sm font-semibold text-text-muted group-hover:text-text dark:text-text-dark-muted dark:group-hover:text-text-dark">AI Workflows</span>
              <span class="text-brand-600 dark:text-brand-400 font-bold">&rarr;</span>
            </a>
            <a href="/guides/windows-fixes" class="group flex items-center justify-between p-3 rounded-xl border border-border/50 hover:border-brand-600 dark:border-border-dark/50 dark:hover:border-brand-400 transition-all">
              <span class="text-sm font-semibold text-text-muted group-hover:text-text dark:text-text-dark-muted dark:group-hover:text-text-dark">Windows Fixes</span>
              <span class="text-brand-600 dark:text-brand-400 font-bold">&rarr;</span>
            </a>
            <a href="/guides/productivity" class="group flex items-center justify-between p-3 rounded-xl border border-border/50 hover:border-brand-600 dark:border-border-dark/50 dark:hover:border-brand-400 transition-all">
              <span class="text-sm font-semibold text-text-muted group-hover:text-text dark:text-text-dark-muted dark:group-hover:text-text-dark">Productivity</span>
              <span class="text-brand-600 dark:text-brand-400 font-bold">&rarr;</span>
            </a>
          </nav>
        </div>
        <p class="text-xs text-text-muted dark:text-text-dark-muted mt-4">Practical step-by-step developer checklists.</p>
      </div>

    </div>
  </section>

  <!-- 3. What This Is Section -->
  <section class="border-t border-b border-border/80 dark:border-border-dark/80 bg-surface-alt/40 dark:bg-surface-dark-alt/20 py-16 transition-colors duration-300">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-4">What This Is</h2>
      <p class="text-text-muted dark:text-text-dark-muted leading-relaxed">
        I am an IT Operations Lead, not a software engineer. This site documents how I use AI
        (DeepSeek + OpenCode) to punch above my weight class — building Python scripts, SQL pipelines,
        CLI tools, and IT automations I would never write from scratch. No fluff. No fake expertise.
        Just real experiments with code, including the failures.
      </p>
    </div>
  </section>

  <!-- 4. Remaining Articles Grid -->
  <section class="mx-auto max-w-6xl px-6 py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-text dark:text-text-dark mb-10 text-center">Latest Articles</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {remainingArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/blog"
        class="inline-block rounded-xl border border-border px-8 py-3 text-sm font-semibold text-text transition-all hover:bg-surface-alt dark:border-border-dark dark:text-text-dark dark:hover:bg-surface-dark-alt"
      >
        View All Articles
      </a>
    </div>
  </section>

  <!-- 5. Explore Topics Cloud -->
  <section class="border-t border-border/80 dark:border-border-dark/80 bg-surface-alt/40 dark:bg-surface-dark-alt/20 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark text-center mb-8">Explore Topics</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {categories
          .sort((a, b) => a.data.order - b.data.order)
          .map((cat) => (
            <a
              href={`/guides/${cat.id}`}
              class="rounded-full border border-border bg-surface px-5 py-2 text-sm font-medium transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:hover:border-brand-400 dark:hover:text-brand-400"
            >
              {cat.data.name}
            </a>
          ))}
      </div>
    </div>
  </section>

  <!-- 6. Trusted Resource Stats -->
  <section class="mx-auto max-w-6xl px-6 py-20 text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-text dark:text-text-dark mb-10">Trusted Resource</h2>
    <div class="mx-auto grid max-w-3xl gap-8 md:grid-cols-3 mb-10">
      <div>
        <p class="mb-1 text-4xl font-extrabold text-brand-600 dark:text-brand-400">100%</p>
        <p class="text-sm font-semibold text-text-muted dark:text-text-dark-muted">Human-written content</p>
      </div>
      <div>
        <p class="mb-1 text-4xl font-extrabold text-brand-600 dark:text-brand-400">Zero</p>
        <p class="text-sm font-semibold text-text-muted dark:text-text-dark-muted">AI-generated fluff</p>
      </div>
      <div>
        <p class="mb-1 text-4xl font-extrabold text-brand-600 dark:text-brand-400">Practical</p>
        <p class="text-sm font-semibold text-text-muted dark:text-text-dark-muted">Guides you can use today</p>
      </div>
    </div>
    <p class="mx-auto max-w-2xl text-text-muted dark:text-text-dark-muted leading-relaxed">
      Every guide is tested, verified, and written for real people. No fluff, no
      filler, no AI-generated spam. Just practical technology knowledge you can
      use today.
    </p>
  </section>
</BaseLayout>
