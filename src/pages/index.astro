---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLatestArticles, getFeaturedArticles } from "@lib/content/posts";
import { getCollection } from "astro:content";
import ArticleCard from "@components/content/ArticleCard.astro";

const latestArticles = await getLatestArticles(6);
const featuredArticles = await getFeaturedArticles();
const categories = await getCollection("categories");
---

<BaseLayout
  seo={{
    title: "IT Ops Lead Builds with AI | Automation, Scripts & Experiments",
    description:
      "An IT Operations Lead documents how DeepSeek and OpenCode are used to build automation scripts, data pipelines, and IT tools. Honest battle logs of AI experiments including where the code failed.",
  }}
>
  <section class="mx-auto max-w-6xl px-4 py-20 text-center md:py-28">
    <div class="mx-auto mb-10 max-w-xl">
      <svg viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" aria-hidden="true">
        <rect x="80" y="30" width="240" height="130" rx="8" class="fill-brand-100 stroke-brand-300 dark:fill-brand-900/30 dark:stroke-brand-700" stroke="currentColor" stroke-width="2"/>
        <rect x="100" y="50" width="200" height="4" rx="2" class="fill-brand-300 dark:fill-brand-600"/>
        <rect x="100" y="62" width="160" height="3" rx="1.5" class="fill-brand-200 dark:fill-brand-700"/>
        <rect x="100" y="72" width="140" height="3" rx="1.5" class="fill-brand-200 dark:fill-brand-700"/>
        <rect x="100" y="82" width="170" height="3" rx="1.5" class="fill-brand-200 dark:fill-brand-700"/>
        <rect x="100" y="92" width="120" height="3" rx="1.5" class="fill-brand-200 dark:fill-brand-700"/>
        <rect x="100" y="108" width="180" height="40" rx="4" class="fill-brand-50 stroke-brand-200 dark:fill-brand-900/20 dark:stroke-brand-700" stroke="currentColor" stroke-width="1.5"/>
        <rect x="110" y="118" width="50" height="4" rx="2" class="fill-brand-400 dark:fill-brand-500"/>
        <rect x="170" y="118" width="90" height="4" rx="2" class="fill-brand-300 dark:fill-brand-600"/>
        <rect x="110" y="130" width="80" height="4" rx="2" class="fill-brand-300 dark:fill-brand-600"/>
        <rect x="200" y="50" width="80" height="3" rx="1.5" class="fill-brand-200 dark:fill-brand-700"/>
        <rect x="200" y="60" width="60" height="3" rx="1.5" class="fill-brand-200 dark:fill-brand-700"/>
        <path d="M80 160c0-8 8-12 16-12h208c8 0 16 4 16 12v4H80v-4z" class="fill-brand-200 dark:fill-brand-800"/>
        <rect x="178" y="164" width="44" height="12" rx="2" class="fill-brand-300 dark:fill-brand-600"/>
        <circle cx="200" cy="176" r="4" class="fill-brand-100 stroke-brand-300 dark:fill-brand-900/30 dark:stroke-brand-700" stroke="currentColor" stroke-width="1"/>
        <g class="animate-pulse" opacity="0.6">
          <circle cx="290" cy="70" r="24" class="fill-brand-200 dark:fill-brand-800"/>
          <circle cx="290" cy="70" r="8" class="fill-white dark:fill-brand-900/50"/>
          <circle cx="290" cy="70" r="3" class="fill-brand-400 dark:fill-brand-500"/>
          <line x1="302" y1="58" x2="312" y2="48" stroke="currentColor" stroke-width="2" class="stroke-brand-300 dark:stroke-brand-600"/>
          <line x1="278" y1="82" x2="268" y2="92" stroke="currentColor" stroke-width="2" class="stroke-brand-300 dark:stroke-brand-600"/>
        </g>
      </svg>
    </div>
    <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
      IT Ops Lead
      <span class="text-brand-600 dark:text-brand-400"> Builds with AI</span>
    </h1>
    <p class="mx-auto mb-10 max-w-2xl text-lg text-text-muted dark:text-text-dark-muted md:text-xl">
      I use DeepSeek and OpenCode to build automation scripts, data pipelines, and IT tools. This is where I document what works, what breaks, and what I learn.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="/blog"
        class="rounded-lg bg-brand-600 px-8 py-3.5 text-sm font-medium text-white transition-all hover:bg-brand-700 hover:shadow-lg"
      >
        Browse Articles
      </a>
      <a
        href="/guides"
        class="rounded-lg border border-border px-8 py-3.5 text-sm font-medium text-text transition-all hover:bg-surface-alt dark:border-border-dark dark:text-text-dark dark:hover:bg-surface-dark-alt"
      >
        View Guides
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold">What This Is</h2>
      <p class="text-text-muted dark:text-text-dark-muted">
        I am an IT Operations Lead, not a software engineer. This site documents how I use AI
        (DeepSeek + OpenCode) to punch above my weight class — building Python scripts, SQL pipelines,
        CLI tools, and IT automations I would never write from scratch. No fluff. No fake expertise.
        Just real experiments with code, including the failures.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-8 text-center text-2xl font-bold">Explore by Topic</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-border bg-surface p-6 dark:border-border-dark dark:bg-surface-dark">
          <h3 class="mb-2 font-semibold text-brand-600 dark:text-brand-400">AI Automation Scripts</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Python scripts, CLI tools, and data pipelines built using DeepSeek and OpenCode. Each post includes the exact prompts used, where the AI hallucinated, and how I fixed it. Topics: database auditing, file processing, API automation, report generation.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 dark:border-border-dark dark:bg-surface-dark">
          <h3 class="mb-2 font-semibold text-brand-600 dark:text-brand-400">Build in Public</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Honest battle logs of an IT Ops Lead learning to build with AI. Code that compiled but used nonexistent libraries. Prompts that produced perfect-looking but wrong results. Architectural decisions I had to override. Real experiments, no fake expertise.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 dark:border-border-dark dark:bg-surface-dark">
          <h3 class="mb-2 font-semibold text-brand-600 dark:text-brand-400">IT Operations &amp; Infrastructure</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Database auditing, ERP data pipelines, system admin checklists, and infrastructure best practices from an operations lead perspective. SQL query vaults, backup scripts, and automation patterns for enterprise IT environments.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 dark:border-border-dark dark:bg-surface-dark">
          <h3 class="mb-2 font-semibold text-brand-600 dark:text-brand-400">Windows Troubleshooting</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Fix Windows 11 and 10 errors including update failures, blue screens, slow performance, internet connectivity issues, search problems, and audio glitches. Every fix includes exact menu paths, keyboard shortcuts, and PowerShell commands.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 dark:border-border-dark dark:bg-surface-dark">
          <h3 class="mb-2 font-semibold text-brand-600 dark:text-brand-400">Website Setup &amp; SEO</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Step-by-step guides for setting up Google Search Console, fixing indexing errors, submitting sitemaps, improving Core Web Vitals, and optimizing your site for search engines. Covers GA4 setup, canonical tags, robots.txt configuration, and technical SEO fundamentals.</p>
        </div>
        <div class="rounded-xl border border-border bg-surface p-6 dark:border-border-dark dark:bg-surface-dark">
          <h3 class="mb-2 font-semibold text-brand-600 dark:text-brand-400">Prompt Engineering</h3>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">The exact prompts I use with DeepSeek to build working code. What prompt structures produce reliable output, where AI code review catches bugs, and how to iterate when the first result is wrong. Prompt patterns for SQL, Python, and bash.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="mb-10 text-center text-2xl font-bold">Choose Your Goal</h2>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      <a href="/category/ai-tools" class="group rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:hover:border-brand-400">
        <h3 class="mb-2 font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">AI Tools</h3>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">Discover tools that save you hours every week.</p>
      </a>
      <a href="/guides/productivity" class="group rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:hover:border-brand-400">
        <h3 class="mb-2 font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">Productivity</h3>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">Workflows and systems to get more done.</p>
      </a>
      <a href="/guides/ai-workflows" class="group rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:hover:border-brand-400">
        <h3 class="mb-2 font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">AI Workflows</h3>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">Step-by-step guides to using AI effectively.</p>
      </a>
      <a href="/category/windows-fixes" class="group rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:hover:border-brand-400">
        <h3 class="mb-2 font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">Windows Fixes</h3>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">Solve common Windows problems quickly.</p>
      </a>
      <a href="/category/android-fixes" class="group rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:hover:border-brand-400">
        <h3 class="mb-2 font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">Android Fixes</h3>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">Fix Android issues without frustration.</p>
      </a>
      <a href="/category/career-growth" class="group rounded-xl border border-border p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:hover:border-brand-400">
        <h3 class="mb-2 font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">Career Growth</h3>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">Use technology to advance your career.</p>
      </a>
    </div>
  </section>

  {
    featuredArticles.length > 0 && (
      <section class="bg-surface-alt py-16 dark:bg-surface-dark-alt">
        <div class="mx-auto max-w-6xl px-4">
          <h2 class="mb-10 text-center text-2xl font-bold">Featured Guides</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredArticles.map((article) => (
              <ArticleCard article={article} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="mb-10 text-center text-2xl font-bold">Latest Articles</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {latestArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
    <div class="mt-10 text-center">
      <a
        href="/blog"
        class="inline-block rounded-lg border border-border px-8 py-3 text-sm font-medium text-text transition-all hover:bg-surface-alt dark:border-border-dark dark:text-text-dark dark:hover:bg-surface-dark-alt"
      >
        View All Articles
      </a>
    </div>
  </section>

  <section class="bg-surface-alt py-16 dark:bg-surface-dark-alt">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-10 text-center text-2xl font-bold">Explore Topics</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {categories
          .sort((a, b) => a.data.order - b.data.order)
          .map((cat) => (
            <a
              href={`/category/${cat.id}`}
              class="rounded-full border border-border bg-surface px-5 py-2 text-sm font-medium transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:hover:border-brand-400 dark:hover:text-brand-400"
            >
              {cat.data.name}
            </a>
          ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="rounded-2xl border border-border bg-gradient-to-br from-brand-50 to-white p-10 text-center dark:border-border-dark dark:from-brand-900/20 dark:to-surface-dark">
      <h2 class="mb-4 text-2xl font-bold">Stay Connected</h2>
      <p class="mx-auto mb-8 max-w-lg text-text-muted dark:text-text-dark-muted">
        Follow on <a href="https://x.com/praveenwithapen" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:underline dark:text-brand-400">X (Twitter)</a> or <a href="https://www.linkedin.com/in/praveen-kumar-says/" target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:underline dark:text-brand-400">LinkedIn</a> for the latest guides.
      </p>
    </div>
  </section>

  <section class="bg-surface-alt py-16 dark:bg-surface-dark-alt">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h2 class="mb-6 text-2xl font-bold">Trusted Resource</h2>
      <div class="mx-auto grid max-w-3xl gap-8 md:grid-cols-3">
        <div>
          <p class="mb-1 text-3xl font-bold text-brand-600 dark:text-brand-400">100%</p>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Human-written content</p>
        </div>
        <div>
          <p class="mb-1 text-3xl font-bold text-brand-600 dark:text-brand-400">Zero</p>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">AI-generated fluff</p>
        </div>
        <div>
          <p class="mb-1 text-3xl font-bold text-brand-600 dark:text-brand-400">Practical</p>
          <p class="text-sm text-text-muted dark:text-text-dark-muted">Guides you can use today</p>
        </div>
      </div>
      <p class="mx-auto mt-10 max-w-2xl text-text-muted dark:text-text-dark-muted">
        Every guide is tested, verified, and written for real people. No fluff, no
        filler, no AI-generated spam. Just practical technology knowledge you can
        use today.
      </p>
    </div>
  </section>
</BaseLayout>
