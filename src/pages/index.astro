---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLatestArticles, getFeaturedArticles } from "@lib/content/posts";
import { getCollection } from "astro:content";
import ArticleCard from "@components/content/ArticleCard.astro";

const latestArticles = await getLatestArticles(6);
const featuredArticles = await getFeaturedArticles();
const categories = await getCollection("categories");

const topFeatured = featuredArticles[0] || latestArticles[0];
const remainingArticles = latestArticles.filter(art => art.id !== topFeatured?.id).slice(0, 5);

const categoryIcons: Record<string, string> = {
  "website-setup":   "🌐",
  "windows-fixes":   "🛠️",
  "hosting-infra":   "☁️",
  "ai-websites":     "🤖",
  "ai-automation":   "⚙️",
  "it-operations":   "🖥️",
  "build-in-public": "📢",
};
---

<BaseLayout
  seo={{
    title: "PraveenTechWorld — AI Automation, IT Ops & Windows Guides",
    description:
      "Real experiments using DeepSeek & AI to build automation scripts, fix Windows issues, and document what actually works — from an IT Ops Lead who builds in public.",
  }}
>
  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden border-b border-border dark:border-border-dark">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 dark:border-brand-800/40 dark:bg-brand-900/20 dark:text-brand-400 mb-6">
          <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Building in Public
        </span>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl mb-6 text-text dark:text-text-dark">
          AI that actually
          <span class="bg-gradient-to-r from-brand-600 to-brand-400 dark:from-brand-400 dark:to-brand-300 bg-clip-text text-transparent">works in the real world</span>
        </h1>
        <p class="text-lg text-text-muted dark:text-text-dark-muted max-w-2xl leading-relaxed mb-8">
          I'm an IT Operations Lead — not a developer. I use DeepSeek and OpenCode to build automation scripts, data pipelines, and IT tools. This site documents what works, what breaks, and exactly how I fix it.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/blog" class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/20">
            Read All Articles
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/guides" class="inline-flex items-center gap-2 rounded-xl border border-border px-6 py-3 text-sm font-semibold text-text transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:text-text-dark dark:hover:border-brand-400 dark:hover:text-brand-400">
            Browse Guides
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BENTO GRID ═══ -->
  <section class="mx-auto max-w-6xl px-6 py-14">
    <div class="grid gap-5 md:grid-cols-3 lg:grid-cols-3">

      <!-- Featured Article (spans 2 cols) -->
      {topFeatured && (
        <div class="group md:col-span-2 relative overflow-hidden rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt flex flex-col min-h-[400px] transition-all duration-300 hover:shadow-2xl hover:border-brand-600/50 dark:hover:border-brand-400/50">
          {topFeatured.data.coverImage ? (
            <div class="relative h-52 overflow-hidden border-b border-border dark:border-border-dark">
              <img
                src={topFeatured.data.coverImage}
                alt={topFeatured.data.imageAlt || topFeatured.data.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
          ) : (
            <div class="relative h-52 bg-gradient-to-br from-brand-600/10 via-brand-500/5 to-transparent border-b border-border dark:border-border-dark flex items-center justify-center overflow-hidden">
              <span class="font-mono text-brand-600/30 dark:text-brand-400/20 text-sm">[ {topFeatured.id}.py ]</span>
            </div>
          )}
          <div class="flex flex-col flex-grow p-7">
            <span class="inline-block px-2.5 py-1 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-brand-200/50 dark:border-brand-800/40 w-fit">
              {topFeatured.data.category}
            </span>
            <a href={`/blog/${topFeatured.id}`} class="block">
              <h2 class="text-xl md:text-2xl font-extrabold tracking-tight text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-3 line-clamp-2">
                {topFeatured.data.seoTitle || topFeatured.data.title}
              </h2>
            </a>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed line-clamp-2 mb-4">
              {topFeatured.data.description}
            </p>
            <a href={`/blog/${topFeatured.id}`} class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400 hover:underline">
              Read article
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      )}

      <!-- Category Navigation Card -->
      <div class="rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-7 flex flex-col min-h-[400px] transition-all duration-300 hover:shadow-xl">
        <h3 class="text-base font-bold tracking-tight text-text dark:text-text-dark mb-1">Browse by Topic</h3>
        <p class="text-xs text-text-muted dark:text-text-dark-muted mb-5">Pick where you want to start</p>
        <nav class="flex flex-col gap-2 flex-grow">
          {categories
            .sort((a, b) => a.data.order - b.data.order)
            .map((cat) => (
              <a href={`/guides/${cat.id}`} class="group flex items-center gap-3 p-3 rounded-xl border border-transparent hover:border-brand-200 hover:bg-brand-50/50 dark:hover:border-brand-800/50 dark:hover:bg-brand-900/10 transition-all duration-200">
                <span class="text-lg leading-none">{categoryIcons[cat.id] || "📄"}</span>
                <span class="text-sm font-semibold text-text-muted group-hover:text-text dark:text-text-dark-muted dark:group-hover:text-text-dark transition-colors">{cat.data.name}</span>
                <svg class="ml-auto w-3.5 h-3.5 text-text-muted/40 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            ))}
        </nav>
      </div>

    </div>
  </section>

  <!-- ═══ WHAT THIS IS ═══ -->
  <section class="border-t border-b border-border/60 dark:border-border-dark/60 bg-surface-alt/50 dark:bg-surface-dark-alt/30 py-14">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-8 md:grid-cols-3 items-center">
        <div class="md:col-span-2">
          <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark mb-4">What you get here</h2>
          <p class="text-text-muted dark:text-text-dark-muted leading-relaxed mb-4">
            I am an IT Operations Lead, not a software engineer. This site documents how I use AI
            (DeepSeek + OpenCode) to build Python scripts, SQL pipelines, CLI tools, and IT automations I would never write from scratch. No fluff. No fake expertise.
            Just real experiments with code — including the failures.
          </p>
          <a href="/about" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400 hover:underline">
            Learn more about this project →
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { num: "69+", label: "Published guides" },
            { num: "3", label: "New posts daily" },
            { num: "7", label: "Topic categories" },
            { num: "Real", label: "Tested experiments" },
          ].map(stat => (
            <div class="rounded-2xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-5 text-center">
              <p class="text-2xl font-extrabold text-brand-600 dark:text-brand-400 mb-1">{stat.num}</p>
              <p class="text-xs font-medium text-text-muted dark:text-text-dark-muted">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ LATEST ARTICLES ═══ -->
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark">Latest Articles</h2>
      <a href="/blog" class="text-sm font-semibold text-brand-600 dark:text-brand-400 hover:underline">
        View all →
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {remainingArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
    <div class="mt-12 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 rounded-xl border border-border px-8 py-3 text-sm font-semibold text-text transition-all hover:bg-surface-alt hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:text-text-dark dark:hover:bg-surface-dark-alt dark:hover:border-brand-400 dark:hover:text-brand-400"
      >
        Browse all {69}+ articles
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </section>

  <!-- ═══ EXPLORE TOPICS ═══ -->
  <section class="border-t border-border/60 dark:border-border-dark/60 bg-surface-alt/50 dark:bg-surface-dark-alt/30 py-14">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark text-center mb-8">Explore Topics</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {categories
          .sort((a, b) => a.data.order - b.data.order)
          .map((cat) => (
            <a
              href={`/guides/${cat.id}`}
              class="flex items-center gap-2 rounded-full border border-border bg-surface px-5 py-2.5 text-sm font-medium transition-all hover:border-brand-600 hover:text-brand-600 hover:shadow-md dark:border-border-dark dark:bg-surface-dark dark:hover:border-brand-400 dark:hover:text-brand-400"
            >
              <span>{categoryIcons[cat.id] || "📄"}</span>
              {cat.data.name}
            </a>
          ))}
      </div>
    </div>
  </section>
</BaseLayout>
