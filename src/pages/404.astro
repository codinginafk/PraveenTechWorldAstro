---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  noindex={true}
  seo={{
    title: "Page Not Found",
    description: "Page not found. The page you are looking for does not exist or was moved. Browse tech guides, AI tutorials, and Windows fixes to find what you need.",
  }}
>
  <div class="mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="mb-4 text-6xl font-bold text-brand-600 dark:text-brand-400">404</h1>
    <h2 class="mb-4 text-2xl font-bold">Page Not Found</h2>
    <p class="mb-8 text-text-muted dark:text-text-dark-muted">
      The page you are looking for does not exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-block rounded-lg bg-brand-600 px-8 py-3 text-sm font-medium text-white transition-all hover:bg-brand-700"
    >
      Go Home
    </a>
  </div>
</BaseLayout>
