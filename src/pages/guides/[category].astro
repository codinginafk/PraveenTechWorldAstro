---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";
import { getPublishedArticles } from "@lib/content/posts";

export async function getStaticPaths() {
  const categories = await getCollection("categories");
  return categories.map((cat) => ({
    params: { category: cat.id },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allArticles = await getPublishedArticles();
const catArticles = allArticles.filter((a) => a.data.category === category.id);
const catName = category.data.name;
const catDescription = category.data.description;
const catIcon = category.data.icon || "📘";

const cats = await getCollection("categories");
const otherCats = cats.filter((c) => c.id !== category.id).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  seo={{
    title: `${catName} Guides and Tutorials`,
    description: `Browse ${catName.toLowerCase()} guides. ${catDescription}`.slice(0, 150),
  }}
>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <nav class="mb-4 text-sm text-text-muted dark:text-text-dark-muted">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
      <span class="mx-2">/</span>
      <a href="/guides" class="hover:text-brand-600 dark:hover:text-brand-400">Guides</a>
      <span class="mx-2">/</span>
      <span>{catName}</span>
    </nav>

    <div class="mb-12">
      <span class="mb-2 block text-4xl">{catIcon}</span>
      <h1 class="mb-4 text-3xl font-bold">{catName} Guide Series</h1>
      <p class="max-w-3xl text-lg text-text-muted dark:text-text-dark-muted">
        {catDescription}
      </p>
    </div>

    {catArticles.length === 0 && (
      <p class="py-12 text-center text-text-muted dark:text-text-dark-muted">
        No guides in this series yet. Check back soon.
      </p>
    )}

    <div class="space-y-6">
      {catArticles.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()).map((article, i) => (
        <a
          href={`/blog/${article.id}`}
          class="group block rounded-xl border border-border bg-surface p-6 transition-all hover:-translate-y-0.5 hover:border-brand-600 hover:shadow-md dark:border-border-dark dark:bg-surface-dark dark:hover:border-brand-400"
        >
          <div class="flex items-start gap-4">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-100 text-sm font-bold text-brand-700 dark:bg-brand-900/30 dark:text-brand-300">
              {i + 1}
            </span>
            <div class="min-w-0 flex-1">
              <h2 class="text-lg font-semibold group-hover:text-brand-600 dark:group-hover:text-brand-400">
                {article.data.seoTitle || article.data.title}
              </h2>
              <p class="mt-1 text-sm text-text-muted dark:text-text-dark-muted">
                {article.data.description}
              </p>
              <div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-text-muted dark:text-text-dark-muted">
                <span>{new Date(article.data.publishDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
                {article.data.readingTime && <span>{article.data.readingTime} min read</span>}
                {article.data.tags.length > 0 && (
                  <span class="flex flex-wrap gap-1">
                    {article.data.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-full bg-surface-alt px-2 py-0.5 text-xs dark:bg-surface-dark-alt">{tag}</span>
                    ))}
                  </span>
                )}
              </div>
            </div>
            <svg class="mt-1 h-5 w-5 shrink-0 text-text-muted transition-transform group-hover:translate-x-1 group-hover:text-brand-600 dark:group-hover:text-brand-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    {otherCats.length > 0 && (
      <div class="mt-16 border-t border-border pt-10 dark:border-border-dark">
        <h2 class="mb-6 text-xl font-bold">Explore Other Guide Series</h2>
        <div class="flex flex-wrap gap-3">
          {otherCats.map((c) => (
            <a
              href={`/guides/${c.id}`}
              class="rounded-full border border-border bg-surface px-5 py-2 text-sm font-medium transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:hover:border-brand-400 dark:hover:text-brand-400"
            >
              {c.data.icon && <span class="mr-1">{c.data.icon}</span>}
              {c.data.name}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
