---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getPublishedArticles } from "@lib/content/posts";

const categories = await getCollection("categories");
const allArticles = await getPublishedArticles();

const categoryIcons: Record<string, string> = {
  "website-setup":   "🌐",
  "windows-fixes":   "🛠️",
  "hosting-infra":   "☁️",
  "ai-websites":     "🤖",
  "ai-automation":   "⚙️",
  "it-operations":   "🖥️",
  "build-in-public": "📢",
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allArticles.filter(a => a.data.category === cat.id).length,
}));
---

<BaseLayout
  seo={{
    title: "Topic Guides — AI Automation, Windows Fixes, Website Setup & More",
    description:
      "Browse step-by-step guides organized by topic. AI automation scripts, Windows troubleshooting, website setup, hosting, IT operations, and more.",
  }}
>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="mb-12">
      <h1 class="text-3xl font-extrabold tracking-tight text-text dark:text-text-dark mb-3">Browse by Topic</h1>
      <p class="text-text-muted dark:text-text-dark-muted">
        {allArticles.length} guides across {categories.length} topic areas. Pick a category to start.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {categoryCounts
        .sort((a, b) => a.data.order - b.data.order)
        .map(cat => (
          <a
            href={`/guides/${cat.id}`}
            class="group flex flex-col rounded-2xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark p-7 transition-all duration-300 hover:border-brand-600/50 hover:shadow-xl hover:-translate-y-1 dark:hover:border-brand-400/50"
          >
            <div class="flex items-start justify-between mb-4">
              <span class="text-3xl">{categoryIcons[cat.id] || "📄"}</span>
              <span class="text-xs font-semibold text-brand-600 dark:text-brand-400 bg-brand-50 dark:bg-brand-900/20 border border-brand-200/50 dark:border-brand-800/40 rounded-full px-2.5 py-1">
                {cat.count} guide{cat.count !== 1 ? "s" : ""}
              </span>
            </div>
            <h2 class="text-lg font-bold text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-2">
              {cat.data.name}
            </h2>
            <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed flex-grow">
              {cat.data.description || `Step-by-step guides for ${cat.data.name.toLowerCase()}.`}
            </p>
            <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold text-brand-600 dark:text-brand-400">
              Browse guides
              <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </a>
        ))}
    </div>
  </div>
</BaseLayout>
