---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedArticles } from "@lib/content/posts";
import ArticleCard from "@components/content/ArticleCard.astro";

const articles = await getPublishedArticles();
---

<BaseLayout
  seo={{
    title: "All Guides by Topic — Website, Windows & AI Tutorials",
    description:
      "Browse step-by-step practical guides on AI, productivity, automation, and technology. Learn new skills with clear tutorials for beginners and professionals",
  }}
>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="mb-3 text-3xl font-bold">Guides</h1>
    <p class="mb-10 text-text-muted dark:text-text-dark-muted">
      Step-by-step guides to help you learn faster and work smarter.
    </p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>

    {articles.length === 0 && (
      <p class="py-12 text-center text-text-muted dark:text-text-dark-muted">
        No guides published yet.
      </p>
    )}
  </div>
</BaseLayout>
