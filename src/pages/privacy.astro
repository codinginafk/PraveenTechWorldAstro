---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  seo={{
    title: "Privacy Policy",
    description: "Read how PraveenTechWorld protects your privacy. Learn what data we collect, how we use cookies, and your rights regarding your personal information.",
  }}
>
  <article class="prose mx-auto max-w-3xl px-4 py-16 dark:prose-invert">
    <h1>Privacy Policy</h1>
    <p>
      PraveenTechWorld respects your privacy. This policy explains how we handle
      your information.
    </p>
    <h2>Information We Collect</h2>
    <p>
      We do not collect personal information. We use standard web analytics to
      understand how visitors use our site. This data is anonymized.
    </p>
    <h2>Cookies</h2>
    <p>
      We use minimal cookies for site functionality (theme preference). We do not
      use tracking cookies.
    </p>
    <h2>Third-Party Services</h2>
    <p>
      We may use Vercel for hosting and analytics. Their privacy policies apply
      to data they process.
    </p>
    <h2>Contact</h2>
    <p>
      Questions about this policy? Email{" "}
      <a href="mailto:hello@praveentechworld.com">hello@praveentechworld.com</a>.
    </p>
  </article>
</BaseLayout>
