---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedArticles } from "@lib/content/posts";
import ArticleCard from "@components/content/ArticleCard.astro";

const articles = await getPublishedArticles();
const toolArticles = articles.filter(
  (a) => a.data.category === "ai-tools" || a.data.category === "free-software"
);
---

<BaseLayout
  seo={{
    title: "Tool Reviews",
    description:
      "Honest reviews and comparisons of AI tools and free software.",
  }}
>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="mb-3 text-3xl font-bold">Tool Reviews</h1>
    <p class="mb-10 text-text-muted dark:text-text-dark-muted">
      Honest reviews to help you discover better tools.
    </p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {toolArticles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>

    {toolArticles.length === 0 && (
      <p class="py-12 text-center text-text-muted dark:text-text-dark-muted">
        Tool reviews coming soon.
      </p>
    )}
  </div>
</BaseLayout>
