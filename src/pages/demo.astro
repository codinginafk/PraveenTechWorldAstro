---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="transition-colors duration-300">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Visual Redesign Sandbox & Demo Site</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <script is:inline>
      // Sync theme status before load to prevent page flashes
      (function () {
        const theme = localStorage.getItem("theme") || "light";
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body class="bg-surface text-text dark:bg-surface-dark dark:text-text-dark antialiased transition-colors duration-300 min-h-screen flex flex-col font-sans">
    
    <!-- Sticky Glassmorphic Header Menu -->
    <header class="sticky top-0 z-50 border-b border-border/85 bg-surface/80 dark:border-border-dark/85 dark:bg-surface-dark/80 backdrop-blur-md transition-colors duration-300">
      <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
        <a href="#" class="text-xl font-extrabold tracking-tight text-text dark:text-text-dark">
          Praveen<span class="text-brand-600 dark:text-brand-400">TechWorld</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-8">
          <a href="#" class="text-sm font-semibold text-text/80 dark:text-text-dark/80 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Home</a>
          <a href="#" class="text-sm font-semibold text-text/80 dark:text-text-dark/80 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Blog</a>
          <a href="#" class="text-sm font-semibold text-text/80 dark:text-text-dark/80 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Guides</a>
        </nav>
        
        <div class="flex items-center gap-4">
          <!-- Light/Dark Mode Switch Button -->
          <button id="theme-toggle" class="p-2 rounded-xl border border-border dark:border-border-dark hover:bg-surface-alt dark:hover:bg-surface-dark-alt text-text-muted dark:text-text-dark-muted transition-all cursor-pointer" aria-label="Toggle visual theme">
            <!-- Sun Icon (visible in dark mode) -->
            <svg id="sun-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707.707M12 7a5 5 0 100 10 5 5 0 000-10z" />
            </svg>
            <!-- Moon Icon (visible in light mode) -->
            <svg id="moon-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      
      <!-- 1. Hero Block -->
      <section class="mx-auto max-w-4xl px-6 py-16 text-center">
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl mb-6">
          Premium Bento Grid <span class="bg-gradient-to-r from-brand-600 to-brand-400 dark:from-brand-500 dark:to-brand-300 bg-clip-text text-transparent">Content Landing</span>
        </h1>
        <p class="text-lg text-text-muted dark:text-text-dark-muted max-w-2xl mx-auto mb-8">
          This demo showcases our light theme (default) and dark mode implementation, custom layouts, and sitemap FAQ indexing validations.
        </p>
      </section>

      <!-- 2. Responsive Bento Grid Section -->
      <section class="mx-auto max-w-6xl px-6 mb-20">
        <div class="grid gap-6 md:grid-cols-3">
          
          <!-- Large Card (Span 2) -->
          <div class="bento-card group md:col-span-2 relative overflow-hidden rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-8 flex flex-col justify-between min-h-[320px] transition-all duration-300 hover:shadow-xl hover:border-brand-600 dark:hover:border-brand-400">
            <div>
              <span class="inline-block px-3 py-1 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-brand-200/50 dark:border-brand-800/40">AI Automation</span>
              <h3 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-2">Automate Weekly Student Grade Reports</h3>
              <p class="text-sm text-text-muted dark:text-text-dark-muted mb-6 leading-relaxed max-w-xl">A complete Python data pipeline using DeepSeek prompts to process grade spreadsheets, format PDF structures, and schedule weekly mail delivery.</p>
            </div>
            <div class="aspect-video w-full rounded-2xl bg-gradient-to-br from-brand-600/15 via-brand-500/5 to-transparent border border-border dark:border-border-dark/50 flex items-center justify-center font-mono text-sm text-brand-600 dark:text-brand-400">
              [ grade_report_pipeline.py ]
            </div>
          </div>

          <!-- Small Card -->
          <div class="bento-card group relative overflow-hidden rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-8 flex flex-col justify-between min-h-[320px] transition-all duration-300 hover:shadow-xl hover:border-brand-600 dark:hover:border-brand-400">
            <div>
              <span class="inline-block px-3 py-1 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-brand-200/50 dark:border-brand-800/40">Windows Fixes</span>
              <h3 class="text-xl font-bold tracking-tight text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-2">Fix Update Error 0x800f0922</h3>
              <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">Resolve failed Windows 11 updates with PowerShell registry cleans and partition checks.</p>
            </div>
            <div class="text-xs font-semibold text-brand-600 dark:text-brand-400 mt-4">&rarr; Read Fix Guide</div>
          </div>

          <!-- Small Card -->
          <div class="bento-card group relative overflow-hidden rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-8 flex flex-col justify-between min-h-[320px] transition-all duration-300 hover:shadow-xl hover:border-brand-600 dark:hover:border-brand-400">
            <div>
              <span class="inline-block px-3 py-1 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-brand-200/50 dark:border-brand-800/40">Technical SEO</span>
              <h3 class="text-xl font-bold tracking-tight text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-2">Fix Sitemap Crawl Indexing Block</h3>
              <p class="text-sm text-text-muted dark:text-text-dark-muted leading-relaxed">How to audit and submit clean robots.txt policies to Google and Bing Webmaster consoles.</p>
            </div>
            <div class="text-xs font-semibold text-brand-600 dark:text-brand-400 mt-4">&rarr; Read SEO Guide</div>
          </div>

          <!-- Large Card (Span 2) -->
          <div class="bento-card group md:col-span-2 relative overflow-hidden rounded-3xl border border-border dark:border-border-dark bg-surface dark:bg-surface-dark-alt p-8 flex flex-col justify-between min-h-[320px] transition-all duration-300 hover:shadow-xl hover:border-brand-600 dark:hover:border-brand-400">
            <div>
              <span class="inline-block px-3 py-1 bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 rounded-full text-xs font-bold uppercase tracking-wider mb-4 border border-brand-200/50 dark:border-brand-800/40">Build in Public</span>
              <h3 class="text-2xl font-extrabold tracking-tight text-text dark:text-text-dark group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-2">Lessons from Running Local SEO Agents</h3>
              <p class="text-sm text-text-muted dark:text-text-dark-muted mb-6 leading-relaxed max-w-xl">An honest battle log of handling prompt drift, Google Search Console rate limits, and server-side process locks in our automated site auditor.</p>
            </div>
            <div class="aspect-video w-full rounded-2xl bg-gradient-to-br from-brand-600/15 via-brand-500/5 to-transparent border border-border dark:border-border-dark/50 flex items-center justify-center font-mono text-sm text-brand-600 dark:text-brand-400">
              [ orchestrator_lock_logs.json ]
            </div>
          </div>

        </div>
      </section>

      <!-- 3. Article Detail Layout & Open FAQ Demonstration -->
      <section class="border-t border-border dark:border-border-dark bg-surface-alt dark:bg-surface-dark-alt/30 py-20 transition-colors duration-300">
        <div class="mx-auto max-w-4xl px-6">
          <div class="mb-8">
            <span class="text-xs font-bold uppercase tracking-wider text-brand-600 dark:text-brand-400 mb-2 block">Article Layout Showcase</span>
            <h2 class="text-3xl font-extrabold tracking-tight text-text dark:text-text-dark">Sitemap-Safe Content Structure</h2>
          </div>
          
          <div class="prose dark:prose-invert max-w-none mb-12">
            <p class="text-text-muted dark:text-text-dark-muted text-base leading-relaxed mb-6">
              To guarantee that Googlebot and Bingbot index our troubleshooting content, all helper guides render fully expanded FAQs by default. Hiding them inside JavaScript collapse variables is risky for DA-20 sites. We use native semantic components:
            </p>
          </div>

          <!-- FAQ Grid: Open by default for crawler indexability -->
          <div class="space-y-4">
            
            <details open class="group border border-border dark:border-border-dark rounded-2xl bg-surface dark:bg-surface-dark p-6 transition-colors duration-300">
              <summary class="list-none flex items-center justify-between font-bold text-lg text-text dark:text-text-dark cursor-pointer">
                <span>Will Google index FAQs that are open by default?</span>
                <span class="text-brand-600 dark:text-brand-400 group-open:rotate-180 transition-transform duration-200">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </span>
              </summary>
              <div class="mt-4 pt-4 border-t border-border/50 dark:border-border-dark/50 text-text-muted dark:text-text-dark-muted text-sm leading-relaxed">
                Yes! Search engines read the raw HTML payload. Having the FAQ item marked as <code>open</code> in the HTML markup ensures crawler scripts capture the text instantly, indexing the details block for search snippet queries.
              </div>
            </details>

            <details open class="group border border-border dark:border-border-dark rounded-2xl bg-surface dark:bg-surface-dark p-6 transition-colors duration-300">
              <summary class="list-none flex items-center justify-between font-bold text-lg text-text dark:text-text-dark cursor-pointer">
                <span>How do we prevent URL/slug indexing drops?</span>
                <span class="text-brand-600 dark:text-brand-400 group-open:rotate-180 transition-transform duration-200">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                </span>
              </summary>
              <div class="mt-4 pt-4 border-t border-border/50 dark:border-border-dark/50 text-text-muted dark:text-text-dark-muted text-sm leading-relaxed">
                All visual design layouts are mapped contextually. No slugs are changed during build generation. If a URL is moved, we add a server-level 301 redirect rule inside <code>vercel.json</code> to forward bot spider crawlers instantly.
              </div>
            </details>

          </div>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="border-t border-border dark:border-border-dark py-8 text-center bg-surface dark:bg-surface-dark transition-colors duration-300">
      <p class="text-xs text-text-muted dark:text-text-dark-muted">
        &copy; 2026 PraveenTechWorld. All rights reserved.
      </p>
    </footer>

    <!-- Client-Side Theme Toggler Script -->
    <script is:inline>
      const btn = document.getElementById("theme-toggle");
      const sun = document.getElementById("sun-icon");
      const moon = document.getElementById("moon-icon");

      function updateUI(theme) {
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
          sun.classList.remove("hidden");
          moon.classList.add("hidden");
        } else {
          document.documentElement.classList.remove("dark");
          sun.classList.add("hidden");
          moon.classList.remove("hidden");
        }
      }

      // Read state
      let currentTheme = localStorage.getItem("theme") || "light";
      updateUI(currentTheme);

      btn.addEventListener("click", () => {
        currentTheme = currentTheme === "light" ? "dark" : "light";
        localStorage.setItem("theme", currentTheme);
        updateUI(currentTheme);
      });
    </script>
  </body>
</html>
