---
import { getCollection } from "astro:content";

const currentYear = new Date().getFullYear();
const cats = await getCollection("categories");
// Show top 10 categories by order, formatted in a two-column grid
const topCats = cats.sort((a, b) => a.data.order - b.data.order).slice(0, 10);
---

<footer class="border-t border-border/40 dark:border-border-dark/40 bg-surface-alt/20 dark:bg-surface-dark-alt/10">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

      <!-- Brand -->
      <div class="max-w-xs">
        <a href="/" class="text-lg font-extrabold tracking-tight text-brand-600 dark:text-brand-400">
          PraveenTechWorld
        </a>
        <p class="mt-2 text-xs leading-relaxed text-text-muted dark:text-text-dark-muted">
          AI automation, Windows fixes, and IT guides, tested and verified by an IT Ops Lead.
        </p>
        <div class="mt-4 flex gap-2.5">
          <a
            href="https://x.com/praveenwithapen"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-8 w-8 items-center justify-center rounded-lg border border-border bg-surface text-text-muted transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:text-text-dark-muted dark:hover:border-brand-400 dark:hover:text-brand-400"
            aria-label="X (Twitter)"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/praveen-kumar-says/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-8 w-8 items-center justify-center rounded-lg border border-border bg-surface text-text-muted transition-all hover:border-brand-600 hover:text-brand-600 dark:border-border-dark dark:bg-surface-dark dark:text-text-dark-muted dark:hover:border-brand-400 dark:hover:text-brand-400"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links row -->
      <div class="flex flex-wrap gap-12 text-sm">
        <!-- Navigate -->
        <div>
          <h2 class="text-[11px] font-bold uppercase tracking-wider text-text dark:text-text-dark mb-3">Navigate</h2>
          <ul class="space-y-1.5">
            {[
              { href: "/blog", label: "Blog" },
              { href: "/guides", label: "Guides" },
              { href: "/tools", label: "Tools" },
              { href: "/portfolio", label: "Portfolio" },
              { href: "/about", label: "About" },
              { href: "/contact", label: "Contact" },
            ].map(link => (
              <li>
                <a href={link.href} class="text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400 transition-colors text-[13px]">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Topics -->
        <div class="min-w-[200px]">
          <h2 class="text-[11px] font-bold uppercase tracking-wider text-text dark:text-text-dark mb-3">Topics</h2>
          <ul class="grid grid-cols-2 gap-x-6 gap-y-1.5">
            {topCats.map((cat) => (
              <li>
                <a href={`/guides/${cat.id}`} class="text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400 transition-colors text-[13px] whitespace-nowrap">
                  {cat.data.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h2 class="text-[11px] font-bold uppercase tracking-wider text-text dark:text-text-dark mb-3">Legal</h2>
          <ul class="space-y-1.5">
            <li>
              <a href="/privacy" class="text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400 transition-colors text-[13px]">
                Privacy
              </a>
            </li>
            <li>
              <a href="/terms" class="text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400 transition-colors text-[13px]">
                Terms
              </a>
            </li>
            <li>
              <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400 transition-colors text-[13px]">
                RSS
              </a>
            </li>
          </ul>
        </div>
      </div>

    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-border/30 dark:border-border-dark/30 text-center text-[11px] text-text-muted dark:text-text-dark-muted">
      &copy; {currentYear} PraveenTechWorld. All rights reserved.
    </div>
  </div>
</footer>
