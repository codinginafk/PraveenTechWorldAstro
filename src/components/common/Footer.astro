---
import { getCollection } from "astro:content";

const currentYear = new Date().getFullYear();
const cats = await getCollection("categories");
---

<footer class="border-t border-border dark:border-border-dark">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-text-muted dark:text-text-dark-muted">
          About
        </h2>
        <p class="mb-4 text-sm text-text-muted dark:text-text-dark-muted">
          Practical technology guides, productivity tips, and AI workflows to help you work smarter.
        </p>
        <div class="flex gap-3">
          <a href="https://x.com/praveenwithapen" target="_blank" rel="noopener noreferrer" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span class="sr-only">X (Twitter)</span>
          </a>
          <a href="https://www.linkedin.com/in/praveen-kumar-says/" target="_blank" rel="noopener noreferrer" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span class="sr-only">LinkedIn</span>
          </a>
        </div>
      </div>
      <div>
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-text-muted dark:text-text-dark-muted">
          Quick Links
        </h2>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">Blog</a></li>
          <li><a href="/guides" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">Guides</a></li>
          <li><a href="/tools" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">Tool Reviews</a></li>
          <li><a href="/about" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">About</a></li>
          <li><a href="/contact" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">Contact</a></li>
          <li><a href="/rss.xml" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400" target="_blank" rel="noopener noreferrer">RSS Feed</a></li>
        </ul>
      </div>
      <div>
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-text-muted dark:text-text-dark-muted">
          Topics
        </h2>
        <ul class="space-y-2 text-sm">
          {cats.sort((a, b) => a.data.order - b.data.order).map((cat) => (
            <li>
              <a href={`/guides/${cat.id}`} class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">
                {cat.data.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-text-muted dark:text-text-dark-muted">
          Legal
        </h2>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">Privacy Policy</a></li>
          <li><a href="/terms" class="text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-border pt-6 text-center text-xs text-text-muted dark:border-border-dark dark:text-text-dark-muted">
      &copy; {currentYear} PraveenTechWorld. All rights reserved.
    </div>
  </div>
</footer>
