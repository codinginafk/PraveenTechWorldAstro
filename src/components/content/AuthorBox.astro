---
import type { CollectionEntry } from "astro:content";

export interface Props {
  author: CollectionEntry<"authors"> | undefined;
}

const { author } = Astro.props;
---

{
  author && (
    <div class="flex items-center gap-4 rounded-xl border border-border bg-surface-alt p-6 dark:border-border-dark dark:bg-surface-dark-alt">
      <div class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-100 text-lg font-bold text-brand-700 dark:bg-brand-900/30 dark:text-brand-300">
        {author.data.name.charAt(0)}
      </div>
      <div>
        <p class="font-semibold text-text dark:text-text-dark">{author.data.name}</p>
        <p class="text-sm text-text-muted dark:text-text-dark-muted">{author.data.bio}</p>
        <div class="mt-1 flex gap-2">
          {author.data.twitter && (
            <a href={author.data.twitter} target="_blank" rel="noopener noreferrer" class="text-xs text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">
              X (Twitter)
            </a>
          )}
          {author.data.linkedin && (
            <a href={author.data.linkedin} target="_blank" rel="noopener noreferrer" class="text-xs text-text-muted hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400">
              LinkedIn
            </a>
          )}
        </div>
      </div>
    </div>
  )
}
