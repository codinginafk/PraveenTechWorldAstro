---
export interface Props {
  variant?: "category" | "tag" | "default";
  href?: string;
}

const { variant = "default", href } = Astro.props;

const variantClasses: Record<string, string> = {
  category:
    "bg-brand-100 text-brand-700 dark:bg-brand-900/30 dark:text-brand-300",
  tag: "bg-surface-alt text-text-muted dark:bg-surface-dark-alt dark:text-text-dark-muted",
  default:
    "bg-surface-alt text-text-muted dark:bg-surface-dark-alt dark:text-text-dark-muted",
};

const Tag = href ? "a" : "span";
---

<Tag
  {...(href ? { href } : {})}
  class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium transition-colors ${variantClasses[variant]}`}
>
  <slot />
</Tag>
