---
export interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
---

{
  headings.length > 0 && (
    <nav class="rounded-xl border border-border bg-surface-alt p-4 dark:border-border-dark dark:bg-surface-dark-alt" aria-label="Table of contents">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-text-muted dark:text-text-dark-muted">
        On this page
      </p>
      <ul class="space-y-1.5">
        {headings
          .filter((h) => h.depth <= 3)
          .map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class="block text-sm text-text-muted transition-colors hover:text-brand-600 dark:text-text-dark-muted dark:hover:text-brand-400"
                style={{ paddingLeft: `${(heading.depth - 2) * 1}rem` }}
              >
                {heading.text}
              </a>
            </li>
          ))}
      </ul>
    </nav>
  )
}
