---
export interface Props {
  references: Array<{
    title: string;
    url: string;
    author?: string;
    publisher?: string;
  }>;
}

const { references } = Astro.props;
---

<section class="mt-10 rounded-xl border border-border bg-surface-alt p-6 dark:border-border-dark dark:bg-surface-dark-alt">
  <h2 class="mb-4 text-lg font-bold">References</h2>
  <ol class="space-y-3 text-sm">
    {references.map((ref, i) => (
      <li class="pl-2">
        <a
          href={ref.url}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="font-medium text-brand-600 hover:underline dark:text-brand-400"
        >
          {ref.title}
        </a>
        {ref.publisher && (
          <span class="text-text-muted dark:text-text-dark-muted">
            {" "}— {ref.publisher}
          </span>
        )}
      </li>
    ))}
  </ol>
</section>
