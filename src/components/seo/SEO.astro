---
import { buildPageTitle, buildCanonical, type SEOMetadata } from "@lib/seo/metadata";

export interface Props extends SEOMetadata {
  noindex?: boolean;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage,
  canonical,
  noindex,
} = Astro.props;

const siteUrl = "https://praveentechworld.com";
const siteName = "PraveenTechWorld";
const pageTitle = buildPageTitle(title);
const pageCanonical = canonical || buildCanonical(siteUrl, Astro.url.pathname);
const ogImg = ogImage || `${siteUrl}/images/og-default.svg`;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={pageCanonical} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={ogTitle || pageTitle} />
<meta property="og:description" content={ogDescription || description} />
<meta property="og:url" content={pageCanonical} />
<meta property="og:image" content={ogImg} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle || pageTitle} />
<meta name="twitter:description" content={ogDescription || description} />
<meta name="twitter:image" content={ogImg} />

{noindex && <meta name="robots" content="noindex, nofollow" />}
