---
const siteUrl = "https://www.praveentechworld.com";
const siteName = "PraveenTechWorld";
const contactEmail = "hello@praveentechworld.com";
---

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  description: "Practical technology guides, productivity tips, and AI workflows.",
  inLanguage: "en-US",
})} />

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/favicon/favicon.svg`,
  email: contactEmail,
  sameAs: [
    "https://x.com/praveenwithapen",
    "https://www.linkedin.com/in/praveen-kumar-says/",
  ],
})} />

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: siteName,
  url: siteUrl,
  description: "Practical technology guides, how-to tutorials, AI workflows, productivity tips, and troubleshooting solutions.",
  inLanguage: "en-US",
  isPartOf: {
    "@type": "WebSite",
    name: siteName,
    url: siteUrl,
  },
})} />
