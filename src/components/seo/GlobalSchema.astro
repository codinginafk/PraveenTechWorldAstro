---
const siteUrl = "https://www.praveentechworld.com";
const siteName = "PraveenTechWorld";
---

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  description: "Practical technology guides, productivity tips, and AI workflows.",
  inLanguage: "en-US",
})} />

<script type="application/ld+json" is:inline set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/favicon/favicon.svg`,
  sameAs: [
    "https://x.com/praveenwithapen",
    "https://linkedin.com/in/praveen-kumar-says/",
  ],
})} />
