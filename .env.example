# Unsplash API (free, register at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=

# LLM API (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL=mimo-v2.5-free

# News API
CURRENTS_API_KEY=

# Google Analytics
PUBLIC_GA_ID=G-TR2F3NPMVN

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dev.to Syndication
DEVTO_API_KEY=

# Hashnode Syndication
HASHNODE_PAT=

# Google Search Console API (OAuth service account)
# 1. Go to https://console.cloud.google.com/
# 2. Create a project, enable Search Console API
# 3. Create a service account, download JSON key (any IAM role works, e.g. Viewer)
# 4. Save JSON key as gcp-service-account.json in project root
# 5. Go to GSC -> Settings -> Users -> Add user -> paste service account email -> Owner (Full)
#    Note: If GSC says 'email not found', wait 5-10 min for propagation then retry.
GOOGLE_SERVICE_ACCOUNT_PATH=gcp-service-account.json
